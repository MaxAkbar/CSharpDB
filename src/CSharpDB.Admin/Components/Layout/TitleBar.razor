@inject ThemeService Theme
@inject TabManagerService TabManager
@inject ICSharpDbClient DbClient
@inject DatabaseClientHolder DbHolder
@inject DatabaseChangeService Changes
@inject ModalService Modal
@inject ToastService Toast
@implements IDisposable

<div class="titlebar">
    <div class="titlebar-logo">
        <img src="icon2.png?v=20260310"
             alt="CSharpDB Studio"
             class="titlebar-logo-image"
             width="24"
             height="24" />
        <span class="titlebar-brand">CSharpDB Studio</span>
    </div>
    <button class="db-switcher" @onclick="OpenDatabase" title="Switch database">
        <i class="bi bi-database"></i>
        <span>@CurrentDatabaseName</span>
        <i class="bi bi-caret-down-fill"></i>
    </button>
    <button class="palette-launcher" @onclick="OpenCommandPalette" title="Command Palette (Ctrl+K)">
        <i class="bi bi-search"></i>
        <span>Search anything...</span>
        <span class="kbd">Ctrl K</span>
    </button>
    <div class="titlebar-toolbar">
        <button class="titlebar-action-btn" @onclick="() => TabManager.OpenQueryTab()" title="New Query (Ctrl+N)">
            <i class="bi bi-plus"></i> New Query
        </button>
        <button class="titlebar-action-btn" @onclick="() => TabManager.OpenTableDesignerTab()" title="New Table">
            <i class="bi bi-table"></i> New Table
        </button>
        <button class="titlebar-action-btn" @onclick="() => TabManager.OpenFormDesignerTab()" title="New Form">
            <i class="bi bi-ui-checks-grid"></i> New Form
        </button>
        <button class="titlebar-action-btn" @onclick="() => TabManager.OpenNewProcedureTab()" title="New Procedure">
            <i class="bi bi-gear-wide-connected"></i> New Procedure
        </button>
        <button class="titlebar-action-btn" @onclick="() => TabManager.OpenPipelineTab()" title="New Pipeline">
            <i class="bi bi-diagram-3"></i> Pipeline
        </button>
        <button class="titlebar-action-btn" @onclick="() => TabManager.OpenStorageTab()" title="Storage Inspector">
            <i class="bi bi-hdd-stack"></i> Storage
        </button>
    </div>
    <div class="titlebar-center">
        <span class="status-dot connected"></span>
        Connected
    </div>
    <div class="titlebar-actions">
        <button class="titlebar-btn" title="Toggle Theme (Ctrl+Shift+L)" @onclick="ToggleTheme">
            <i class="bi @(Theme.IsDark ? "bi-moon-stars" : "bi-sun")"></i>
        </button>
        <button class="titlebar-btn" title="Toggle Sidebar (Ctrl+B)" @onclick="ToggleSidebar">
            <i class="bi bi-layout-sidebar-inset"></i>
        </button>
        <button class="titlebar-btn" title="Keyboard Shortcuts" @onclick="ShowShortcuts">
            <i class="bi bi-keyboard"></i>
        </button>
    </div>
</div>

@code {
    [Parameter] public EventCallback OnToggleSidebar { get; set; }
    [Parameter] public EventCallback OnShowShortcuts { get; set; }
    [Parameter] public EventCallback OnOpenCommandPalette { get; set; }

    private string CurrentDatabaseName
    {
        get
        {
            string source = DbHolder.DataSource ?? DbClient.DataSource ?? string.Empty;
            if (string.IsNullOrWhiteSpace(source))
                return "Open database";

            try
            {
                return Path.GetFileName(source.TrimEnd(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar));
            }
            catch
            {
                return source;
            }
        }
    }

    protected override void OnInitialized()
    {
        Theme.ThemeChanged += OnThemeChanged;
        DbHolder.DatabaseChanged += OnDatabaseChanged;
    }

    private async Task ToggleTheme() => await Theme.ToggleAsync();
    private async Task ToggleSidebar() => await OnToggleSidebar.InvokeAsync();
    private async Task ShowShortcuts() => await OnShowShortcuts.InvokeAsync();
    private async Task OpenCommandPalette() => await OnOpenCommandPalette.InvokeAsync();

    private async Task OpenDatabase()
    {
        var path = await Modal.PromptAsync(
            "Open Database",
            "Enter the path to the database file:",
            confirmText: "Open",
            placeholder: @"C:\path\to\database.db",
            defaultValue: DbClient.DataSource);

        if (string.IsNullOrWhiteSpace(path))
            return;

        try
        {
            await DbHolder.SwitchAsync(path.Trim());
            Toast.Success($"Opened database '{DbHolder.DataSource}'.");
            Changes.NotifyChanged();
        }
        catch (Exception ex)
        {
            Toast.Error($"Failed to open database: {ex.Message}");
        }
    }

    private void OnThemeChanged() => InvokeAsync(StateHasChanged);
    private void OnDatabaseChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Theme.ThemeChanged -= OnThemeChanged;
        DbHolder.DatabaseChanged -= OnDatabaseChanged;
    }
}
