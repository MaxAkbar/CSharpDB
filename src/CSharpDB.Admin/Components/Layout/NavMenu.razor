                             @oncontextmenu="e => ShowReportItemMenu(e, currentReport)"
                             @oncontextmenu:preventDefault>
                            <i class="bi bi-file-earmark-richtext icon-view"></i>
                            <span class="item-label">@currentReport.Name</span>
                            <span class="item-hint">@currentReport.Source.Name</span>
                        </div>
                    }
                </div>
            }
        </div>
        }

