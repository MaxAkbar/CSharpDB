        catch (Exception ex) { Toast.Error(ex.Message); }
    }

    private async Task ConfirmDeleteFormAsync(FormDefinition form)
    {
        var confirmed = await Modal.ConfirmAsync("Delete Form", $"Are you sure you want to delete form '{form.Name}'?", "Delete", isDanger: true);
        if (!confirmed) return;

        try
        {
            await FormRepository.DeleteAsync(form.FormId);
            Toast.Success($"Deleted form '{form.Name}'.");
            TabManager.CloseTabsForForm(form.FormId);
            Changes.NotifyChanged();
        }
        catch (Exception ex)
        {
            Toast.Error(ex.Message);
        }
    }

    private async Task ConfirmDeleteReportAsync(ReportDefinition report)
    {
        var confirmed = await Modal.ConfirmAsync("Delete Report", $"Are you sure you want to delete report '{report.Name}'?", "Delete", isDanger: true);
        if (!confirmed) return;

        try
        {
            await ReportRepository.DeleteAsync(report.ReportId);
            Toast.Success($"Deleted report '{report.Name}'.");
            TabManager.CloseTabsForReport(report.ReportId);
            Changes.NotifyChanged();
        }
        catch (Exception ex)
        {
            Toast.Error(ex.Message);
        }
    }

    public void Dispose()
    {
        Changes.Changed -= OnChanged;
        DbHolder.DatabaseChanged -= OnDatabaseChanged;
        TabManager.StateChanged -= OnTabChanged;
    }

    private static bool IsSystemTableName(string name) =>
        name.StartsWith("_", StringComparison.Ordinal);
}
