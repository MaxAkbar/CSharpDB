                <i class="bi @(_expandedGroups.Contains("reports") ? "bi-chevron-down" : "bi-chevron-right")"></i>
                <i class="bi bi-file-earmark-richtext icon-view"></i>
                <span>Reports</span>
                <span class="group-count">@(_reports?.Count ?? 0)</span>
