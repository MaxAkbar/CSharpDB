@inject ICSharpDbClient DbClient
@inject DatabaseChangeService Changes
@inject TabManagerService TabManager
@inject ToastService Toast
@inject ModalService Modal
@inject IJSRuntime JS
@implements IDisposable

<aside class="sidebar">
    <div class="sidebar-header">
        <span>Object Explorer</span>
        <button class="sidebar-collapse-btn" title="Collapse All" @onclick="CollapseAll">
            <i class="bi bi-arrows-collapse"></i>
        </button>
    </div>

    <div class="sidebar-search">
        <i class="bi bi-search"></i>
        <input type="text" placeholder="Filter objects..." @bind="_searchQuery" @bind:event="oninput" />
    </div>

    <div class="tree-container">
        @* User Tables *@
        <div class="tree-group">
            <div class="tree-group-header"
                 @onclick='() => ToggleGroup("tables")'
                 @oncontextmenu="e => ShowTablesGroupMenu(e)"
                 @oncontextmenu:preventDefault>
                <i class="bi @(_expandedGroups.Contains("tables") ? "bi-chevron-down" : "bi-chevron-right")"></i>
                <i class="bi bi-table icon-table"></i>
                <span>User Tables</span>
                <span class="group-count">@(_userTableNames?.Count ?? 0)</span>
            </div>
            @if (_expandedGroups.Contains("tables") && _userTableNames is not null)
            {
                <div class="tree-items">
                    @foreach (var name in FilterItems(_userTableNames))
                    {
                        var tableName = name;
                        <div class="tree-item @(IsActive("table", tableName) ? "active" : "")"
                             @onclick="() => TabManager.OpenTableTab(tableName)"
                             @oncontextmenu="e => ShowTableItemMenu(e, tableName)"
                             @oncontextmenu:preventDefault>
                            <i class="bi bi-table icon-table"></i>
                            <span class="item-label">@tableName</span>
                        </div>
                    }
                </div>
            }
        </div>

        <div class="tree-group">
            <div class="tree-group-header" @onclick='() => ToggleGroup("systemTables")'>
                <i class="bi @(_expandedGroups.Contains("systemTables") ? "bi-chevron-down" : "bi-chevron-right")"></i>
                <i class="bi bi-hdd-stack icon-system"></i>
                <span>System Tables</span>
                <span class="group-count">@(_systemTableNames?.Count ?? 0)</span>
            </div>
            @if (_expandedGroups.Contains("systemTables") && _systemTableNames is not null)
            {
                <div class="tree-items">
                    @foreach (var name in FilterItems(_systemTableNames))
                    {
                        <div class="tree-item @(IsActive("table", name) ? "active" : "")"
                             @onclick="() => TabManager.OpenTableTab(name)">
                            <i class="bi bi-hdd-stack icon-system"></i>
                            <span class="item-label">@name</span>
                        </div>
                    }
                </div>
            }
        </div>

        @* System Catalog (Virtual) *@
        <div class="tree-group">
            <div class="tree-group-header" @onclick='() => ToggleGroup("system")'>
                <i class="bi @(_expandedGroups.Contains("system") ? "bi-chevron-down" : "bi-chevron-right")"></i>
                <i class="bi bi-hdd-stack icon-system"></i>
                <span>System Catalog</span>
                <span class="group-count">@s_systemCatalogItems.Count</span>
            </div>
            @if (_expandedGroups.Contains("system"))
            {
                <div class="tree-items">
                    @foreach (var item in FilterSystemCatalogItems())
                    {
                        <div class="tree-item @(IsActive("system", item.Name) ? "active" : "")"
                             @onclick="() => OpenSystemCatalogTab(item)">
                            <i class="bi bi-hdd-stack icon-system"></i>
                            <span class="item-label">@item.Name</span>
                            <span class="item-hint">@item.Description</span>
                        </div>
                    }
                </div>
            }
        </div>

        @* Views *@
        <div class="tree-group">
            <div class="tree-group-header"
                 @onclick='() => ToggleGroup("views")'
                 @oncontextmenu="e => ShowViewsGroupMenu(e)"
                 @oncontextmenu:preventDefault>
                <i class="bi @(_expandedGroups.Contains("views") ? "bi-chevron-down" : "bi-chevron-right")"></i>
                <i class="bi bi-eye icon-view"></i>
                <span>Views</span>
                <span class="group-count">@(_viewNames?.Count ?? 0)</span>
            </div>
            @if (_expandedGroups.Contains("views") && _viewNames is not null)
            {
                <div class="tree-items">
                    @foreach (var name in FilterItems(_viewNames))
                    {
                        var viewName = name;
                        <div class="tree-item @(IsActive("view", viewName) ? "active" : "")"
                             @onclick="() => TabManager.OpenViewTab(viewName)"
                             @oncontextmenu="e => ShowViewItemMenu(e, viewName)"
                             @oncontextmenu:preventDefault>
                            <i class="bi bi-eye icon-view"></i>
                            <span class="item-label">@viewName</span>
                        </div>
                    }
                </div>
            }
        </div>

        @* Indexes *@
        <div class="tree-group">
            <div class="tree-group-header" @onclick='() => ToggleGroup("indexes")'>
                <i class="bi @(_expandedGroups.Contains("indexes") ? "bi-chevron-down" : "bi-chevron-right")"></i>
                <i class="bi bi-lightning icon-index"></i>
                <span>Indexes</span>
                <span class="group-count">@(_indexes?.Count ?? 0)</span>
            </div>
            @if (_expandedGroups.Contains("indexes") && _indexes is not null)
            {
                <div class="tree-items">
                    @foreach (var idx in FilterIndexes())
                    {
                        var index = idx;
                        <div class="tree-item @(IsActiveSchema("table", index.TableName) ? "active" : "")"
                             @onclick="() => TabManager.OpenTableSchemaTab(index.TableName)"
                             @oncontextmenu="e => ShowIndexItemMenu(e, index)"
                             @oncontextmenu:preventDefault>
                            <i class="bi bi-lightning icon-index"></i>
                            <span class="item-label">@index.IndexName</span>
                            <span class="item-hint">@index.TableName</span>
                        </div>
                    }
                </div>
            }
        </div>

        @* Triggers *@
        <div class="tree-group">
            <div class="tree-group-header" @onclick='() => ToggleGroup("triggers")'>
                <i class="bi @(_expandedGroups.Contains("triggers") ? "bi-chevron-down" : "bi-chevron-right")"></i>
                <i class="bi bi-lightning-charge icon-trigger"></i>
                <span>Triggers</span>
                <span class="group-count">@(_triggers?.Count ?? 0)</span>
            </div>
            @if (_expandedGroups.Contains("triggers") && _triggers is not null)
            {
                <div class="tree-items">
                    @foreach (var trig in FilterTriggers())
                    {
                        var trigger = trig;
                        <div class="tree-item @(IsActiveSchema("table", trigger.TableName) ? "active" : "")"
                             @onclick="() => TabManager.OpenTableSchemaTab(trigger.TableName)"
                             @oncontextmenu="e => ShowTriggerItemMenu(e, trigger)"
                             @oncontextmenu:preventDefault>
                            <i class="bi bi-lightning-charge icon-trigger"></i>
                            <span class="item-label">@trigger.TriggerName</span>
                            <span class="item-hint">@trigger.TableName</span>
                        </div>
                    }
                </div>
            }
        </div>

        @* Procedures *@
        <div class="tree-group">
            <div class="tree-group-header"
                 @onclick='() => ToggleGroup("procedures")'
                 @oncontextmenu="e => ShowProceduresGroupMenu(e)"
                 @oncontextmenu:preventDefault>
                <i class="bi @(_expandedGroups.Contains("procedures") ? "bi-chevron-down" : "bi-chevron-right")"></i>
                <i class="bi bi-gear-wide-connected icon-trigger"></i>
                <span>Procedures</span>
                <span class="group-count">@(_procedures?.Count ?? 0)</span>
            </div>
            @if (_expandedGroups.Contains("procedures") && _procedures is not null)
            {
                <div class="tree-items">
                    @foreach (var procedure in FilterProcedures())
                    {
                        var proc = procedure;
                        <div class="tree-item @(IsActive("procedure", proc.Name) ? "active" : "")"
                             @onclick="() => TabManager.OpenProcedureTab(proc.Name)"
                             @oncontextmenu="e => ShowProcedureItemMenu(e, proc.Name)"
                             @oncontextmenu:preventDefault>
                            <i class="bi bi-gear-wide-connected icon-trigger"></i>
                            <span class="item-label">@proc.Name</span>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <div class="sidebar-resize" @onmousedown="StartResize" @onmousedown:preventDefault></div>
</aside>

<ContextMenu @ref="_contextMenu" Items="_contextMenuItems" />

@code {
    private ContextMenu? _contextMenu;
    private List<ContextMenuItem> _contextMenuItems = new();

    private sealed record SystemCatalogItem(string Name, string Description, string Sql);

    private static readonly IReadOnlyList<SystemCatalogItem> s_systemCatalogItems = new[]
    {
        new SystemCatalogItem("sys.tables", "tables", "SELECT * FROM sys.tables ORDER BY table_name;"),
        new SystemCatalogItem("sys.columns", "columns", "SELECT * FROM sys.columns ORDER BY table_name, ordinal_position;"),
        new SystemCatalogItem("sys.indexes", "indexes", "SELECT * FROM sys.indexes ORDER BY table_name, index_name, ordinal_position;"),
        new SystemCatalogItem("sys.table_stats", "table stats", "SELECT * FROM sys.table_stats ORDER BY table_name;"),
        new SystemCatalogItem("sys.column_stats", "column stats", "SELECT * FROM sys.column_stats ORDER BY table_name, ordinal_position;"),
        new SystemCatalogItem("sys.views", "views", "SELECT * FROM sys.views ORDER BY view_name;"),
        new SystemCatalogItem("sys.triggers", "triggers", "SELECT * FROM sys.triggers ORDER BY trigger_name;"),
        new SystemCatalogItem("sys.objects", "all objects", "SELECT * FROM sys.objects ORDER BY object_type, object_name;"),
        new SystemCatalogItem("sys.saved_queries", "saved queries", "SELECT * FROM sys.saved_queries ORDER BY name;"),
    };

    private IReadOnlyCollection<string>? _userTableNames;
    private IReadOnlyCollection<string>? _systemTableNames;
    private IReadOnlyCollection<string>? _viewNames;
    private IReadOnlyList<IndexSchema>? _indexes;
    private IReadOnlyList<TriggerSchema>? _triggers;
    private IReadOnlyList<ProcedureDefinition>? _procedures;
    private string _searchQuery = string.Empty;
    private readonly HashSet<string> _expandedGroups = new() { "tables", "system", "views", "procedures" };

    protected override async Task OnInitializedAsync()
    {
        Changes.Changed += OnChanged;
        TabManager.StateChanged += OnTabChanged;
        await LoadObjects();
    }

    private async void OnChanged()
    {
        await LoadObjects();
        await InvokeAsync(StateHasChanged);
    }

    private void OnTabChanged() => InvokeAsync(StateHasChanged);

    private async Task LoadObjects()
    {
        try
        {
            var allTables = (await DbClient.GetTableNamesAsync()).OrderBy(n => n).ToList();
            _userTableNames = allTables.Where(static n => !IsSystemTableName(n)).ToList();
            _systemTableNames = allTables.Where(IsSystemTableName).ToList();
            _viewNames = (await DbClient.GetViewNamesAsync()).OrderBy(n => n).ToList();
            _indexes = (await DbClient.GetIndexesAsync()).OrderBy(i => i.IndexName).ToList();
            _triggers = (await DbClient.GetTriggersAsync()).OrderBy(t => t.TriggerName).ToList();
            _procedures = (await DbClient.GetProceduresAsync()).OrderBy(p => p.Name).ToList();
        }
        catch
        {
            _userTableNames = null;
            _systemTableNames = null;
            _viewNames = null;
            _indexes = null;
            _triggers = null;
            _procedures = null;
        }
    }

    private void ToggleGroup(string group)
    {
        if (!_expandedGroups.Remove(group))
            _expandedGroups.Add(group);
    }

    private void CollapseAll() => _expandedGroups.Clear();

    private IEnumerable<string> FilterItems(IReadOnlyCollection<string> items)
    {
        if (string.IsNullOrWhiteSpace(_searchQuery))
            return items;
        return items.Where(n => n.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase));
    }

    private IEnumerable<IndexSchema> FilterIndexes()
    {
        if (_indexes is null) return Enumerable.Empty<IndexSchema>();
        if (string.IsNullOrWhiteSpace(_searchQuery)) return _indexes;
        return _indexes.Where(i => i.IndexName.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase)
                                 || i.TableName.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase));
    }

    private IEnumerable<TriggerSchema> FilterTriggers()
    {
        if (_triggers is null) return Enumerable.Empty<TriggerSchema>();
        if (string.IsNullOrWhiteSpace(_searchQuery)) return _triggers;
        return _triggers.Where(t => t.TriggerName.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase)
                                  || t.TableName.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase));
    }

    private IEnumerable<ProcedureDefinition> FilterProcedures()
    {
        if (_procedures is null) return Enumerable.Empty<ProcedureDefinition>();
        if (string.IsNullOrWhiteSpace(_searchQuery)) return _procedures;
        return _procedures.Where(p => p.Name.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase)
                                   || (p.Description?.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) ?? false));
    }

    private IEnumerable<SystemCatalogItem> FilterSystemCatalogItems()
    {
        if (string.IsNullOrWhiteSpace(_searchQuery))
            return s_systemCatalogItems;

        return s_systemCatalogItems.Where(i =>
            i.Name.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase)
            || i.Description.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase));
    }

    private void OpenSystemCatalogTab(SystemCatalogItem item)
        => TabManager.OpenSystemCatalogTab(item.Name, item.Sql);

    private bool IsActive(string type, string name)
    {
        var activeTab = TabManager.ActiveTab;
        if (activeTab is null) return false;
        return activeTab.Id == $"{type}:{name}";
    }

    private bool IsActiveSchema(string type, string name)
    {
        var activeTab = TabManager.ActiveTab;
        if (activeTab is null) return false;
        return activeTab.Id == $"{type}:{name}";
    }

    private async Task StartResize(MouseEventArgs e)
    {
        try
        {
            await JS.InvokeVoidAsync("resizeInterop.startResize",
                new { clientX = e.ClientX });
        }
        catch { }
    }

    // ═══════════════════════════════════════
    // CONTEXT MENUS
    // ═══════════════════════════════════════

    private void ShowContextMenu(MouseEventArgs e, List<ContextMenuItem> items)
    {
        _contextMenuItems = items;
        _contextMenu?.Show(e.ClientX, e.ClientY);
    }

    private void ShowTablesGroupMenu(MouseEventArgs e)
    {
        ShowContextMenu(e, new List<ContextMenuItem>
        {
            new() { Label = "New Table...", Icon = "bi-plus-lg", OnClick = () => TabManager.OpenTableDesignerTab() },
            ContextMenuItem.Separator(),
            new() { Label = "New Query", Icon = "bi-terminal", OnClick = () => TabManager.OpenQueryTab() },
            new() { Label = "Refresh", Icon = "bi-arrow-clockwise", OnClick = async () => { await LoadObjects(); await InvokeAsync(StateHasChanged); } },
        });
    }

    private void ShowTableItemMenu(MouseEventArgs e, string tableName)
    {
        ShowContextMenu(e, new List<ContextMenuItem>
        {
            new() { Label = "Open", Icon = "bi-table", OnClick = () => TabManager.OpenTableTab(tableName) },
            new() { Label = "Design", Icon = "bi-file-earmark-code", OnClick = () => TabManager.OpenTableSchemaTab(tableName) },
            ContextMenuItem.Separator(),
            new() { Label = "Select Top 50", Icon = "bi-terminal", OnClick = () => TabManager.OpenQueryTab($"SELECT * FROM {tableName} LIMIT 50;") },
            new() { Label = "Select Count", Icon = "bi-123", OnClick = () => TabManager.OpenQueryTab($"SELECT COUNT(*) AS row_count FROM {tableName};") },
            ContextMenuItem.Separator(),
            new() { Label = "Drop Table", Icon = "bi-trash3", IsDanger = true, OnClick = async () => await ConfirmDropTableAsync(tableName) },
        });
    }

    private void ShowViewsGroupMenu(MouseEventArgs e)
    {
        ShowContextMenu(e, new List<ContextMenuItem>
        {
            new() { Label = "New View...", Icon = "bi-plus-lg", OnClick = () => TabManager.OpenQueryTab("CREATE VIEW view_name AS\nSELECT ...;") },
            ContextMenuItem.Separator(),
            new() { Label = "Refresh", Icon = "bi-arrow-clockwise", OnClick = async () => { await LoadObjects(); await InvokeAsync(StateHasChanged); } },
        });
    }

    private void ShowViewItemMenu(MouseEventArgs e, string viewName)
    {
        ShowContextMenu(e, new List<ContextMenuItem>
        {
            new() { Label = "Open", Icon = "bi-eye", OnClick = () => TabManager.OpenViewTab(viewName) },
            new() { Label = "Edit Definition", Icon = "bi-pencil", OnClick = () => { var tab = TabManager.OpenViewTab(viewName); tab.State["ShowSchema"] = true; } },
            ContextMenuItem.Separator(),
            new() { Label = "Select Top 50", Icon = "bi-terminal", OnClick = () => TabManager.OpenQueryTab($"SELECT * FROM {viewName} LIMIT 50;") },
            ContextMenuItem.Separator(),
            new() { Label = "Drop View", Icon = "bi-trash3", IsDanger = true, OnClick = async () => await ConfirmDropViewAsync(viewName) },
        });
    }

    private void ShowIndexItemMenu(MouseEventArgs e, IndexSchema index)
    {
        ShowContextMenu(e, new List<ContextMenuItem>
        {
            new() { Label = "Open Parent Table", Icon = "bi-table", OnClick = () => TabManager.OpenTableSchemaTab(index.TableName) },
            ContextMenuItem.Separator(),
            new() { Label = "Drop Index", Icon = "bi-trash3", IsDanger = true, OnClick = async () => await ConfirmDropIndexAsync(index.IndexName) },
        });
    }

    private void ShowTriggerItemMenu(MouseEventArgs e, TriggerSchema trigger)
    {
        ShowContextMenu(e, new List<ContextMenuItem>
        {
            new() { Label = "Open Parent Table", Icon = "bi-table", OnClick = () => TabManager.OpenTableSchemaTab(trigger.TableName) },
            ContextMenuItem.Separator(),
            new() { Label = "Drop Trigger", Icon = "bi-trash3", IsDanger = true, OnClick = async () => await ConfirmDropTriggerAsync(trigger.TriggerName) },
        });
    }

    private void ShowProceduresGroupMenu(MouseEventArgs e)
    {
        ShowContextMenu(e, new List<ContextMenuItem>
        {
            new() { Label = "New Procedure...", Icon = "bi-plus-lg", OnClick = () => TabManager.OpenNewProcedureTab() },
            ContextMenuItem.Separator(),
            new() { Label = "Refresh", Icon = "bi-arrow-clockwise", OnClick = async () => { await LoadObjects(); await InvokeAsync(StateHasChanged); } },
        });
    }

    private void ShowProcedureItemMenu(MouseEventArgs e, string procName)
    {
        ShowContextMenu(e, new List<ContextMenuItem>
        {
            new() { Label = "Open", Icon = "bi-gear-wide-connected", OnClick = () => TabManager.OpenProcedureTab(procName) },
            ContextMenuItem.Separator(),
            new() { Label = "Delete Procedure", Icon = "bi-trash3", IsDanger = true, OnClick = async () => await ConfirmDeleteProcedureAsync(procName) },
        });
    }

    private async Task ConfirmDropTableAsync(string tableName)
    {
        var confirmed = await Modal.ConfirmAsync("Drop Table", $"Are you sure you want to drop table '{tableName}'? This action cannot be undone.", "Drop", isDanger: true);
        if (!confirmed) return;
        try
        {
            await DbClient.DropTableAsync(tableName);
            Toast.Success($"Dropped table '{tableName}'.");
            TabManager.CloseTabsForObject(tableName);
            Changes.NotifyChanged();
        }
        catch (Exception ex) { Toast.Error(ex.Message); }
    }

    private async Task ConfirmDropViewAsync(string viewName)
    {
        var confirmed = await Modal.ConfirmAsync("Drop View", $"Are you sure you want to drop view '{viewName}'? This action cannot be undone.", "Drop", isDanger: true);
        if (!confirmed) return;
        try
        {
            await DbClient.DropViewAsync(viewName);
            Toast.Success($"Dropped view '{viewName}'.");
            TabManager.CloseTabsForObject(viewName);
            Changes.NotifyChanged();
        }
        catch (Exception ex) { Toast.Error(ex.Message); }
    }

    private async Task ConfirmDropIndexAsync(string indexName)
    {
        var confirmed = await Modal.ConfirmAsync("Drop Index", $"Are you sure you want to drop index '{indexName}'?", "Drop", isDanger: true);
        if (!confirmed) return;
        try
        {
            await DbClient.DropIndexAsync(indexName);
            Toast.Success($"Dropped index '{indexName}'.");
            Changes.NotifyChanged();
        }
        catch (Exception ex) { Toast.Error(ex.Message); }
    }

    private async Task ConfirmDropTriggerAsync(string triggerName)
    {
        var confirmed = await Modal.ConfirmAsync("Drop Trigger", $"Are you sure you want to drop trigger '{triggerName}'?", "Drop", isDanger: true);
        if (!confirmed) return;
        try
        {
            await DbClient.DropTriggerAsync(triggerName);
            Toast.Success($"Dropped trigger '{triggerName}'.");
            Changes.NotifyChanged();
        }
        catch (Exception ex) { Toast.Error(ex.Message); }
    }

    private async Task ConfirmDeleteProcedureAsync(string procName)
    {
        var confirmed = await Modal.ConfirmAsync("Delete Procedure", $"Are you sure you want to delete procedure '{procName}'?", "Delete", isDanger: true);
        if (!confirmed) return;
        try
        {
            await DbClient.DeleteProcedureAsync(procName);
            Toast.Success($"Deleted procedure '{procName}'.");
            TabManager.CloseTabsForObject(procName);
            Changes.NotifyChanged();
        }
        catch (Exception ex) { Toast.Error(ex.Message); }
    }

    public void Dispose()
    {
        Changes.Changed -= OnChanged;
        TabManager.StateChanged -= OnTabChanged;
    }

    private static bool IsSystemTableName(string name) =>
        name.StartsWith("_", StringComparison.Ordinal);
}
