@inherits LayoutComponentBase
@inject TabManagerService TabManager
@inject ThemeService Theme
@inject ModalService Modal
@inject IJSRuntime JS
@implements IDisposable

<div class="app-root">
    <TitleBar OnToggleSidebar="ToggleSidebar"
              OnShowShortcuts="ShowShortcuts"
              OnOpenCommandPalette="OpenCommandPalette" />
    <div class="app-container">
        @if (_sidebarVisible)
        {
            <NavMenu />
        }
        <div class="main-panel">
            <TabBar />
            <div class="content-area">
                @foreach (var tab in TabManager.Tabs)
                {
                    bool isActive = TabManager.ActiveTab?.Id == tab.Id;

                    <div class="tab-content-panel" hidden="@(!isActive)" aria-hidden="@(!isActive)" @key="tab.Id">
                        @switch (tab.Kind)
                        {
                            case TabKind.Welcome:
                                <WelcomeTab />
                                break;
                            case TabKind.Query:
                                <QueryTab @key="tab.Id" Tab="tab" />
                                break;
                            case TabKind.TableData:
                                <DataTab @key="tab.Id"
                                         Tab="tab"
                                         ObjectName="@(tab.ObjectName ?? string.Empty)"
                                         IsView="false" />
                                break;
                            case TabKind.ViewData:
                                <DataTab @key="tab.Id"
                                         Tab="tab"
                                         ObjectName="@(tab.ObjectName ?? string.Empty)"
                                         IsView="true" />
                                break;
                            case TabKind.CollectionData:
                                <CollectionTab @key="tab.Id"
                                               Tab="tab"
                                               CollectionName="@(tab.ObjectName ?? string.Empty)" />
                                break;
                            case TabKind.HostCallbacks:
                                <CallbacksTab @key="tab.Id"
                                              Tab="tab" />
                                break;
                            case TabKind.Procedure:
                                <ProcedureTab @key="tab.Id"
                                              Tab="tab" />
                                break;
                            case TabKind.Pipeline:
                                <PipelineTab @key="tab.Id"
                                             Tab="tab" />
                                break;
                            case TabKind.Storage:
                                <StorageTab @key="tab.Id" />
                                break;
                            case TabKind.TableDesigner:
                                <TableDesignerTab @key="tab.Id"
                                                  Tab="tab" />
                                break;
                            case TabKind.FormDesigner:
                                <FormDesignerTab @key="tab.Id"
                                                 Tab="tab" />
                                break;
                            case TabKind.FormEntry:
                                <FormEntryTab @key="tab.Id"
                                              Tab="tab" />
                                break;
                            case TabKind.ReportDesigner:
                                <ReportDesignerTab @key="tab.Id"
                                                   Tab="tab" />
                                break;
                            case TabKind.ReportPreview:
                                <ReportPreviewTab @key="tab.Id"
                                                  Tab="tab" />
                                break;
                        }
                    </div>
                }
            </div>
        </div>
    </div>
    <StatusBar />
</div>

<ToastContainer />
<ConfirmModal />
<CommandPalette @bind-Visible="_commandPaletteVisible" />

@code {
    private bool _sidebarVisible = true;
    private bool _commandPaletteVisible;
    private DotNetObjectReference<MainLayout>? _dotNetRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Theme.InitializeAsync(JS);
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("keyboardInterop.init", _dotNetRef);
            TabManager.StateChanged += OnTabChanged;
        }
    }

    [JSInvokable]
    public async Task OnKeyboardShortcut(string action)
    {
        switch (action)
        {
            case "NewQuery":
                TabManager.OpenQueryTab();
                break;
            case "ToggleSidebar":
                ToggleSidebar();
                break;
            case "ToggleTheme":
                await Theme.ToggleAsync();
                break;
            case "OpenCommandPalette":
                OpenCommandPalette();
                break;
            case "CloseTab":
                if (TabManager.ActiveTab?.Closable == true)
                    TabManager.CloseTab(TabManager.ActiveTab.Id);
                break;
            case "RunQuery":
                // Handled by SqlEditor component directly
                break;
        }
        await InvokeAsync(StateHasChanged);
    }

    private void ToggleSidebar()
    {
        _sidebarVisible = !_sidebarVisible;
        StateHasChanged();
    }

    private void OpenCommandPalette()
    {
        _commandPaletteVisible = true;
        StateHasChanged();
    }

    private async Task ShowShortcuts()
    {
        await Modal.ConfirmAsync(
            "Keyboard Shortcuts",
            "Ctrl+K - Command palette\nCtrl+N - New query tab\nCtrl+B - Toggle sidebar\nCtrl+Enter - Run query\nCtrl+Shift+L - Toggle theme\nCtrl+W - Close tab\nDouble-click - Edit cell",
            "OK");
    }

    private void OnTabChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        TabManager.StateChanged -= OnTabChanged;
        try { _ = JS.InvokeVoidAsync("keyboardInterop.dispose"); } catch { }
        _dotNetRef?.Dispose();
    }
}
