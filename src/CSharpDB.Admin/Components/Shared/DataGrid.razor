@using System.Diagnostics
@using CSharpDB.Admin.Helpers
@using CSharpDB.Admin.Models
@inject ICSharpDbClient DbClient
@inject DatabaseChangeService Changes
@inject ToastService Toast
@inject ModalService Modal

<div class="grid-container">
    @if (_loading)
    {
        <div class="loading-overlay">
            <div class="spinner"></div>
        </div>
    }
    else if (_loadError is not null)
    {
        <div class="query-error">
            <i class="bi bi-exclamation-triangle"></i> @_loadError
        </div>
    }
    else if (Columns is null || Columns.Length == 0)
    {
        <div class="empty-state">
            <i class="bi bi-table"></i>
            <p>No data to display</p>
        </div>
    }
    else
    {
        <table class="data-grid">
            <thead>
                <tr>
                    <th class="row-num-header">#</th>
                    @for (int c = 0; c < Columns.Length; c++)
                    {
                        var colIdx = c;
                        var sortIndicator = _sortCol == colIdx ? (_sortAsc ? " \u2191" : " \u2193") : "";
                        <th @onclick="() => SortColumn(colIdx)" class="sortable">
                            <span class="col-name">@Columns[colIdx]</span>
                            @if (ColumnTypes is not null && colIdx < ColumnTypes.Length)
                            {
                                <span class="col-type-badge @GetTypeBadgeClass(ColumnTypes[colIdx])">@ColumnTypes[colIdx]</span>
                            }
                            @if (PrimaryKeyColumn is not null && Columns[colIdx] == PrimaryKeyColumn)
                            {
                                <span class="col-pk-badge">PK</span>
                            }
                            <span class="sort-indicator">@sortIndicator</span>
                        </th>
                    }
                </tr>
                @if (ShowFilters)
                {
                    <tr class="filter-row">
                        <td class="row-num-header"></td>
                        @for (int c = 0; c < Columns.Length; c++)
                        {
                            var colIdx = c;
                            <td>
                                <input type="text" class="filter-input" placeholder="Filter..."
                                       value="@GetFilterInput(colIdx)"
                                       @oninput="e => UpdateFilterDraft(colIdx, e.Value?.ToString())"
                                       @onkeydown="e => HandleFilterKeyDown(e, colIdx)" />
                            </td>
                        }
                    </tr>
                }
            </thead>
            <tbody>
                @if (_rows.Count == 0)
                {
                    <tr>
                        <td colspan="@(Columns.Length + 1)" class="empty-cell">No rows found</td>
                    </tr>
                }
                else
                {
                    @for (int r = 0; r < _rows.Count; r++)
                    {
                        var rowIdx = r;
                        var row = _rows[rowIdx];
                        var rowClass = GetRowClass(row);
                        var isSelected = _selectedRows.Contains(row);
                        <tr class="@rowClass @(isSelected ? "selected" : "")"
                            @oncontextmenu="e => ShowRowContextMenu(e, row)"
                            @oncontextmenu:preventDefault>
                            <td class="row-num" @onclick="() => ToggleRowSelect(row)">
                                @((_page - 1) * _pageSize + rowIdx + 1)
                            </td>
                            @for (int c = 0; c < Columns.Length; c++)
                            {
                                var colIdx = c;
                                var isPk = PrimaryKeyColumn is not null && Columns[colIdx] == PrimaryKeyColumn;
                                var cellValue = row.CurrentValues[colIdx];
                                var isEditing = _editingCell?.RowIndex == rowIdx && _editingCell?.ColIndex == colIdx;

                                @if (isEditing)
                                {
                                    <td class="editing">
                                        <input type="text" class="cell-edit-input"
                                               value="@_editingCell!.Value"
                                               @oninput="e => _editingCell!.Value = e.Value?.ToString() ?? string.Empty"
                                               @onblur="() => CommitEdit(rowIdx, colIdx)"
                                               @onkeydown="e => HandleCellKeyDown(e, rowIdx, colIdx)"
                                               autofocus />
                                    </td>
                                }
                                else
                                {
                                    <td class="@(isPk ? "pk-val" : "") @(row.IsColumnModified(colIdx) ? "modified-cell" : "")"
                                        @ondblclick="() => StartEdit(rowIdx, colIdx, isPk)">
                                        @if (cellValue is null)
                                        {
                                            <span class="null-val">NULL</span>
                                        }
                                        else if (cellValue is byte[] bytes)
                                        {
                                            <span class="blob-val">[@bytes.Length bytes]</span>
                                        }
                                        else
                                        {
                                            @cellValue.ToString()
                                        }
                                    </td>
                                }
                            }
                        </tr>
                    }
                }
            </tbody>
        </table>
    }
</div>

@if (_totalRows > 0)
{
    <div class="pagination-bar">
        <div class="page-size-select">
            <select @bind="_pageSize" @bind:after="OnPageSizeChanged">
                <option value="10">10 rows</option>
                <option value="25">25 rows</option>
                <option value="50">50 rows</option>
                <option value="100">100 rows</option>
            </select>
        </div>
        <div class="page-controls">
            <button class="page-btn" disabled="@(_page <= 1)" @onclick="() => GoToPage(1)">
                <i class="bi bi-chevron-double-left"></i>
            </button>
            <button class="page-btn" disabled="@(_page <= 1)" @onclick="() => GoToPage(_page - 1)">
                <i class="bi bi-chevron-left"></i>
            </button>
            <span class="page-info">Page @_page of @TotalPages</span>
            <button class="page-btn" disabled="@(_page >= TotalPages)" @onclick="() => GoToPage(_page + 1)">
                <i class="bi bi-chevron-right"></i>
            </button>
            <button class="page-btn" disabled="@(_page >= TotalPages)" @onclick="() => GoToPage(TotalPages)">
                <i class="bi bi-chevron-double-right"></i>
            </button>
        </div>
        <div class="row-count">@_totalRows rows</div>
    </div>
}

<ContextMenu @ref="_contextMenu" Items="_contextMenuItems" />

@code {
    [Parameter] public string? TableName { get; set; }
    [Parameter] public string? ViewName { get; set; }
    [Parameter] public string? QuerySql { get; set; }
    [Parameter] public int ReloadVersion { get; set; }
    [Parameter] public string[]? Columns { get; set; }
    [Parameter] public string[]? ColumnTypes { get; set; }
    [Parameter] public string? PrimaryKeyColumn { get; set; }
    [Parameter] public bool IsReadOnly { get; set; }
    [Parameter] public bool ShowFilters { get; set; } = true;
    [Parameter] public EventCallback<string> OnStatusMessage { get; set; }
    [Parameter] public EventCallback<int> OnSelectionChanged { get; set; }
    [Parameter] public EventCallback<QueryResultsStatus> OnQueryStatusChanged { get; set; }

    private List<DataGridRow> _allRows = new();
    private List<DataGridRow> _rows = new();
    private bool _loading;
    private string? _loadError;
    private int _page = 1;
    private int _pageSize = 25;
    private int _totalRows;
    private int? _sortCol;
    private bool _sortAsc = true;
    private readonly Dictionary<int, string> _filters = new();
    private readonly Dictionary<int, string> _filterInputs = new();
    private readonly HashSet<DataGridRow> _selectedRows = new();
    private EditingCell? _editingCell;
    private ContextMenu? _contextMenu;
    private List<ContextMenuItem> _contextMenuItems = new();
    private bool _loadedAllRows;
    private string? _lastTableName;
    private string? _lastViewName;
    private string? _lastQuerySql;
    private int _lastReloadVersion;
    private bool _sourceInitialized;
    private QueryPagingPlan? _queryPagingPlan;
    private TimeSpan? _lastQueryElapsed;

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(_totalRows / (double)_pageSize));
    private bool HasActiveFilters => _filters.Values.Any(value => !string.IsNullOrWhiteSpace(value));

    protected override async Task OnParametersSetAsync()
    {
        bool sourceChanged = !_sourceInitialized
            || !string.Equals(_lastTableName, TableName, StringComparison.Ordinal)
            || !string.Equals(_lastViewName, ViewName, StringComparison.Ordinal)
            || !string.Equals(_lastQuerySql, QuerySql, StringComparison.Ordinal);
        bool queryReloadRequested = QuerySql is not null && _lastReloadVersion != ReloadVersion;

        if (!sourceChanged && !queryReloadRequested)
            return;

        _sourceInitialized = true;
        _lastTableName = TableName;
        _lastViewName = ViewName;
        _lastQuerySql = QuerySql;
        _lastReloadVersion = ReloadVersion;

        if (sourceChanged)
        {
            _page = 1;
            _sortCol = null;
            _sortAsc = true;
            _loadedAllRows = false;
            _filters.Clear();
            _filterInputs.Clear();
            Columns = null;
            ColumnTypes = null;
            PrimaryKeyColumn = null;
            _queryPagingPlan = null;
            _loadError = null;
            _lastQueryElapsed = null;
        }

        await LoadDataAsync();
    }

    public async Task LoadDataAsync()
    {
        _loading = true;
        _loadError = null;
        _editingCell = null;
        _selectedRows.Clear();
        await NotifySelectionChangedAsync();
        StateHasChanged();

        try
        {
            if (ShouldLoadAllRows())
                await LoadAllRowsAsync();
            else
                await LoadCurrentPageAsync();

            ApplyFiltersAndSort();
        }
        catch (Exception ex)
        {
            _allRows = new();
            _rows = new();
            _totalRows = 0;
            _loadError = ex.Message;

            if (QuerySql is null)
                Toast.Error($"Failed to load data: {ex.Message}");
        }
        finally
        {
            _loading = false;
            await NotifyQueryStatusChangedAsync();
            StateHasChanged();
        }
    }

    // ─── Sorting ────────────────────
    private async Task SortColumn(int colIdx)
    {
        if (_sortCol == colIdx)
            _sortAsc = !_sortAsc;
        else
        {
            _sortCol = colIdx;
            _sortAsc = true;
        }

        _page = 1;

        if (ShouldLoadAllRows())
        {
            if (!_loadedAllRows)
            {
                await LoadDataAsync();
                return;
            }

            ApplyFiltersAndSort();
            await NotifySelectionChangedAsync();
            StateHasChanged();
            return;
        }

        await LoadDataAsync();
    }

    // ─── Filtering ──────────────────
    private string GetFilterInput(int colIdx)
        => _filterInputs.TryGetValue(colIdx, out var value)
            ? value
            : _filters.TryGetValue(colIdx, out var activeValue)
                ? activeValue
                : string.Empty;

    private void UpdateFilterDraft(int colIdx, string? value)
    {
        if (string.IsNullOrEmpty(value))
            _filterInputs.Remove(colIdx);
        else
            _filterInputs[colIdx] = value;
    }

    private async Task HandleFilterKeyDown(KeyboardEventArgs e, int colIdx)
    {
        if (e.Key == "Enter")
        {
            await ApplyFilterDraftAsync(colIdx);
            return;
        }

        if (e.Key == "Escape")
        {
            ResetFilterDraft(colIdx);
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ApplyFilterDraftAsync(int colIdx)
    {
        string value = GetFilterInput(colIdx);
        if (string.IsNullOrWhiteSpace(value))
        {
            _filters.Remove(colIdx);
            _filterInputs.Remove(colIdx);
        }
        else
        {
            _filters[colIdx] = value;
            _filterInputs[colIdx] = value;
        }

        _page = 1;

        if (ShouldLoadAllRows())
        {
            if (!_loadedAllRows)
            {
                await LoadDataAsync();
                return;
            }

            ApplyFiltersAndSort();
            await NotifySelectionChangedAsync();
            StateHasChanged();
            return;
        }

        await LoadDataAsync();
    }

    private void ResetFilterDraft(int colIdx)
    {
        if (_filters.TryGetValue(colIdx, out var activeValue))
            _filterInputs[colIdx] = activeValue;
        else
            _filterInputs.Remove(colIdx);
    }

    // ─── Row Selection ──────────────
    private async Task ToggleRowSelect(DataGridRow row)
    {
        if (_selectedRows.Contains(row))
            _selectedRows.Remove(row);
        else
            _selectedRows.Add(row);

        await NotifySelectionChangedAsync();
    }

    // ─── Row Context Menu ───────────
    private void ShowRowContextMenu(MouseEventArgs e, DataGridRow row)
    {
        if (IsReadOnly)
            return;

        if (!_selectedRows.Contains(row))
        {
            _selectedRows.Clear();
            _selectedRows.Add(row);
            _ = NotifySelectionChangedAsync();
        }

        var items = new List<ContextMenuItem>
        {
            new() { Label = "Add Row", Icon = "bi-plus-lg", OnClick = () => { AddNewRow(); StateHasChanged(); } },
        };

        if (_selectedRows.Count > 0)
        {
            var count = _selectedRows.Count;
            var label = count == 1 ? "Delete Row" : $"Delete {count} Rows";
            items.Add(new() { Label = label, Icon = "bi-trash", IsDanger = true, OnClick = async () => { await DeleteSelectedRowsAsync(); StateHasChanged(); } });
        }

        if (HasPendingChanges)
        {
            items.Add(ContextMenuItem.Separator());
            items.Add(new() { Label = "Save Changes", Icon = "bi-check-lg", OnClick = async () => { await SaveChangesAsync(); StateHasChanged(); } });
            items.Add(new() { Label = "Discard Changes", Icon = "bi-x-lg", OnClick = async () => { await DiscardChangesAsync(); StateHasChanged(); } });
        }

        _contextMenuItems = items;
        _contextMenu?.Show(e.ClientX, e.ClientY);
    }

    // ─── Inline Editing ─────────────
    private void StartEdit(int rowIdx, int colIdx, bool isPk)
    {
        var row = _rows[rowIdx];
        bool pkLocked = isPk && row.State != RowState.New;
        if (IsReadOnly || pkLocked || row.State == RowState.Deleted) return;
        var val = row.CurrentValues[colIdx];
        _editingCell = new EditingCell
        {
            RowIndex = rowIdx,
            ColIndex = colIdx,
            Value = val?.ToString() ?? string.Empty
        };
    }

    private void CommitEdit(int rowIdx, int colIdx)
    {
        if (_editingCell is null) return;
        var row = _rows[rowIdx];
        var newValue = ParseCellValue(_editingCell.Value, colIdx);
        row.CurrentValues[colIdx] = newValue;

        if (row.State == RowState.Unmodified)
            row.State = RowState.Modified;

        _editingCell = null;
        ApplyFiltersAndSort();
    }

    private void HandleCellKeyDown(KeyboardEventArgs e, int rowIdx, int colIdx)
    {
        if (e.Key == "Enter")
            CommitEdit(rowIdx, colIdx);
        else if (e.Key == "Escape")
            _editingCell = null;
    }

    private object? ParseCellValue(string text, int colIdx)
    {
        if (string.IsNullOrEmpty(text) || text.Equals("NULL", StringComparison.OrdinalIgnoreCase))
            return null;
        if (ColumnTypes is not null && colIdx < ColumnTypes.Length)
        {
            var type = ColumnTypes[colIdx];
            if (type == "INTEGER" && long.TryParse(text, out var l)) return l;
            if (type == "REAL" && double.TryParse(text, out var d)) return d;
        }
        return text;
    }

    // ─── CRUD Actions (called from DataTab toolbar) ──
    public void AddNewRow()
    {
        if (Columns is null) return;
        var values = new object?[Columns.Length];
        var row = new DataGridRow(values, RowState.New);
        _allRows.Add(row);
        ApplyFiltersAndSort();

        int rowIdx = _rows.IndexOf(row);
        if (rowIdx >= 0 && Columns.Length > 0)
        {
            _editingCell = new EditingCell
            {
                RowIndex = rowIdx,
                ColIndex = 0,
                Value = string.Empty
            };
        }

        StateHasChanged();
    }

    public async Task DeleteSelectedRowsAsync()
    {
        foreach (var row in _selectedRows.ToList())
        {
            if (row.State == RowState.New)
                _allRows.Remove(row);
            else
                row.State = RowState.Deleted;
        }
        _selectedRows.Clear();
        ApplyFiltersAndSort();
        await NotifySelectionChangedAsync();
    }

    public async Task SaveChangesAsync()
    {
        if (TableName is null || PrimaryKeyColumn is null) return;
        int saved = 0, errors = 0;

        var pkColIdx = Array.IndexOf(Columns!, PrimaryKeyColumn);

        foreach (var row in _allRows.ToList())
        {
            try
            {
                switch (row.State)
                {
                    case RowState.New:
                        var insertVals = new Dictionary<string, object?>();
                        for (int c = 0; c < Columns!.Length; c++)
                        {
                            if (row.CurrentValues[c] is not null)
                                insertVals[Columns[c]] = row.CurrentValues[c];
                        }
                            if (insertVals.Count > 0)
                            {
                            await DbClient.InsertRowAsync(TableName, insertVals);
                            saved++;
                        }
                        break;

                    case RowState.Modified:
                        var updateVals = new Dictionary<string, object?>();
                        for (int c = 0; c < Columns!.Length; c++)
                            updateVals[Columns[c]] = row.CurrentValues[c];
                        await DbClient.UpdateRowAsync(TableName, PrimaryKeyColumn, row.OriginalValues[pkColIdx]!, updateVals);
                        saved++;
                        break;

                    case RowState.Deleted:
                        await DbClient.DeleteRowAsync(TableName, PrimaryKeyColumn, row.OriginalValues[pkColIdx]!);
                        saved++;
                        break;
                }
            }
            catch (Exception ex)
            {
                errors++;
                Toast.Error($"Row error: {ex.Message}");
            }
        }

        if (saved > 0) Toast.Success($"{saved} change(s) saved");
        if (errors > 0) Toast.Warning($"{errors} error(s) occurred");
        if (saved > 0) Changes.NotifyChanged();

        await LoadDataAsync();
    }

    public async Task DiscardChangesAsync()
    {
        _allRows.Clear();
        _loadedAllRows = false;
        await LoadDataAsync();
    }

    public bool HasPendingChanges => _allRows.Any(r => r.State != RowState.Unmodified);
    public bool HasSelectedRows => _selectedRows.Count > 0;
    public int SelectedRowCount => _selectedRows.Count;

    private void ApplyFiltersAndSort()
    {
        if (!_loadedAllRows)
        {
            _rows = _allRows.ToList();
            _selectedRows.RemoveWhere(row => !_rows.Contains(row));
            return;
        }

        IEnumerable<DataGridRow> query = _allRows;

        foreach (var filter in _filters)
        {
            string needle = filter.Value;
            if (string.IsNullOrWhiteSpace(needle))
                continue;

            int colIdx = filter.Key;
            query = query.Where(row =>
            {
                if (colIdx < 0 || colIdx >= row.CurrentValues.Length)
                    return false;

                object? value = row.CurrentValues[colIdx];
                string text = value switch
                {
                    null => "NULL",
                    byte[] bytes => $"[{bytes.Length} bytes]",
                    _ => value.ToString() ?? string.Empty
                };
                return text.Contains(needle, StringComparison.OrdinalIgnoreCase);
            });
        }

        if (_sortCol is int sortCol)
        {
            query = _sortAsc
                ? query.OrderBy(row => GetSortValue(row, sortCol), CellValueComparer.Instance)
                : query.OrderByDescending(row => GetSortValue(row, sortCol), CellValueComparer.Instance);
        }

        if (_loadedAllRows)
        {
            var filteredRows = query.ToList();
            _totalRows = filteredRows.Count;

            int totalPages = Math.Max(1, (int)Math.Ceiling(_totalRows / (double)_pageSize));
            if (_page > totalPages)
                _page = totalPages;

            int skip = (_page - 1) * _pageSize;
            _rows = filteredRows.Skip(skip).Take(_pageSize).ToList();
        }
        else
        {
            _rows = query.ToList();
        }

        _selectedRows.RemoveWhere(row => !_rows.Contains(row));
    }

    private static object? GetSortValue(DataGridRow row, int colIdx)
    {
        if (colIdx < 0 || colIdx >= row.CurrentValues.Length)
            return null;

        return row.CurrentValues[colIdx];
    }

    private sealed class CellValueComparer : IComparer<object?>
    {
        public static readonly CellValueComparer Instance = new();

        public int Compare(object? x, object? y)
        {
            if (ReferenceEquals(x, y)) return 0;
            if (x is null) return -1;
            if (y is null) return 1;

            if (x is byte[] xb && y is byte[] yb)
                return xb.Length.CompareTo(yb.Length);

            if (x is IComparable cmp && x.GetType() == y.GetType())
                return cmp.CompareTo(y);

            if (double.TryParse(x.ToString(), out var dx) && double.TryParse(y.ToString(), out var dy))
                return dx.CompareTo(dy);

            return StringComparer.OrdinalIgnoreCase.Compare(x.ToString(), y.ToString());
        }
    }

    private async Task NotifySelectionChangedAsync()
    {
        if (OnSelectionChanged.HasDelegate)
            await OnSelectionChanged.InvokeAsync(_selectedRows.Count);
    }

    // ─── Pagination ─────────────────
    private async Task GoToPage(int page)
    {
        _page = Math.Max(1, Math.Min(TotalPages, page));

        if (_loadedAllRows)
        {
            ApplyFiltersAndSort();
            await NotifySelectionChangedAsync();
            StateHasChanged();
            return;
        }

        await LoadDataAsync();
    }

    private async Task OnPageSizeChanged()
    {
        _page = 1;

        if (_loadedAllRows)
        {
            ApplyFiltersAndSort();
            await NotifySelectionChangedAsync();
            StateHasChanged();
            return;
        }

        await LoadDataAsync();
    }

    private bool ShouldLoadAllRows() => QuerySql is null && HasPendingChanges;

    private async Task LoadCurrentPageAsync()
    {
        _loadedAllRows = false;
        _lastQueryElapsed = null;

        if (QuerySql is not null)
        {
            await LoadQueryPageAsync(QuerySql);
            return;
        }

        if (TableName is not null)
        {
            string tableName = RequireIdentifier(TableName);
            var schema = await DbClient.GetTableSchemaAsync(tableName)
                ?? throw new InvalidOperationException($"Table '{tableName}' was not found.");

            ApplyTableSchema(schema);
            await LoadServerPageAsync(tableName);
            return;
        }

        if (ViewName is not null)
        {
            string viewName = RequireIdentifier(ViewName);
            await LoadServerPageAsync(viewName);

            Columns ??= Array.Empty<string>();
            ColumnTypes = null;
            PrimaryKeyColumn = null;
            return;
        }

        _allRows = new();
        _rows = new();
        _totalRows = 0;
    }

    private async Task LoadServerPageAsync(string sourceName)
    {
        var countResult = await DbClient.ExecuteSqlAsync(BuildCountSql(sourceName));
        if (countResult.Error is not null)
            throw new InvalidOperationException(countResult.Error);

        _totalRows = ReadCount(countResult);
        ClampPageToAvailableRows();

        var queryResult = await DbClient.ExecuteSqlAsync(BuildSelectSql(sourceName));
        if (queryResult.Error is not null)
            throw new InvalidOperationException(queryResult.Error);

        _allRows = (queryResult.Rows ?? []).Select(r => new DataGridRow(r)).ToList();

        if (ViewName is not null)
            Columns = queryResult.ColumnNames ?? Array.Empty<string>();
    }

    private async Task LoadQueryPageAsync(string querySql)
    {
        _queryPagingPlan ??= QueryPagingPlan.Parse(querySql);

        var stopwatch = Stopwatch.StartNew();
        try
        {
            string[] displayColumns = Columns ?? Array.Empty<string>();
            QueryCountPlan countPlan = _queryPagingPlan.BuildCountPlan(_filters, displayColumns);

            var countResult = await DbClient.ExecuteSqlAsync(countPlan.Sql);
            if (countResult.Error is not null)
                throw new InvalidOperationException(countResult.Error);

            int rawCount = ReadCount(countResult);
            _totalRows = countPlan.ApplyBasePagination
                ? _queryPagingPlan.ApplyBasePaginationToCount(rawCount)
                : rawCount;

            ClampPageToAvailableRows();

            var pageResult = await DbClient.ExecuteSqlAsync(
                _queryPagingPlan.BuildPageSql(_filters, _sortCol, _sortAsc, _pageSize, _page, displayColumns));
            if (pageResult.Error is not null)
                throw new InvalidOperationException(pageResult.Error);

            if (Columns is null || Columns.Length == 0)
                Columns = pageResult.ColumnNames ?? Array.Empty<string>();
            ColumnTypes = null;
            PrimaryKeyColumn = null;
            _allRows = (pageResult.Rows ?? []).Select(row => new DataGridRow(row)).ToList();
        }
        finally
        {
            stopwatch.Stop();
            _lastQueryElapsed = stopwatch.Elapsed;
        }
    }

    private async Task LoadAllRowsAsync()
    {
        var pendingRows = _allRows
            .Where(row => row.State != RowState.Unmodified)
            .Select(CloneRow)
            .ToList();

        if (TableName is not null)
        {
            string tableName = RequireIdentifier(TableName);
            var schema = await DbClient.GetTableSchemaAsync(tableName)
                ?? throw new InvalidOperationException($"Table '{tableName}' was not found.");
            ApplyTableSchema(schema);

            var result = await DbClient.ExecuteSqlAsync($"SELECT * FROM {tableName}");
            if (result.Error is not null)
                throw new InvalidOperationException(result.Error);

            _allRows = (result.Rows ?? []).Select(r => new DataGridRow(r)).ToList();
        }
        else if (ViewName is not null)
        {
            string viewName = RequireIdentifier(ViewName);
            var result = await DbClient.ExecuteSqlAsync($"SELECT * FROM {viewName}");
            if (result.Error is not null)
                throw new InvalidOperationException(result.Error);

            Columns = result.ColumnNames ?? [];
            ColumnTypes = null;
            PrimaryKeyColumn = null;
            _allRows = (result.Rows ?? []).Select(r => new DataGridRow(r)).ToList();
        }
        else
        {
            _allRows = new();
            _rows = new();
            _totalRows = 0;
            _loadedAllRows = false;
            return;
        }

        MergePendingRows(pendingRows);
        _loadedAllRows = true;
    }

    private void ClampPageToAvailableRows()
    {
        int totalPages = TotalPages;
        if (_page > totalPages)
            _page = totalPages;
    }

    private string BuildSelectSql(string sourceName)
    {
        string whereClause = BuildWhereClause();
        string orderByClause = BuildOrderByClause();
        int offset = (_page - 1) * _pageSize;
        return $"SELECT * FROM {sourceName}{whereClause}{orderByClause} LIMIT {_pageSize} OFFSET {offset}";
    }

    private string BuildCountSql(string sourceName)
        => $"SELECT COUNT(*) FROM {sourceName}{BuildWhereClause()}";

    private string BuildWhereClause()
    {
        if (!HasActiveFilters || Columns is null || Columns.Length == 0)
            return string.Empty;

        var clauses = new List<string>();
        foreach (var filter in _filters.OrderBy(pair => pair.Key))
        {
            if (string.IsNullOrWhiteSpace(filter.Value))
                continue;

            int colIdx = filter.Key;
            if (colIdx < 0 || colIdx >= Columns.Length)
                continue;

            string columnName = RequireIdentifier(Columns[colIdx]);
            string pattern = EscapeSqlString($"%{EscapeLikePattern(filter.Value)}%");
            clauses.Add($"TEXT({columnName}) LIKE '{pattern}' ESCAPE '!'");
        }

        return clauses.Count == 0
            ? string.Empty
            : $" WHERE {string.Join(" AND ", clauses)}";
    }

    private string BuildOrderByClause()
    {
        if (_sortCol is not int sortCol || Columns is null || sortCol < 0 || sortCol >= Columns.Length)
            return string.Empty;

        string columnName = RequireIdentifier(Columns[sortCol]);
        string direction = _sortAsc ? "ASC" : "DESC";
        return $" ORDER BY {columnName} {direction}";
    }

    private async Task NotifyQueryStatusChangedAsync()
    {
        if (!OnQueryStatusChanged.HasDelegate)
            return;

        await OnQueryStatusChanged.InvokeAsync(new QueryResultsStatus
        {
            TotalRows = _totalRows,
            VisibleRows = _rows.Count,
            Page = _page,
            PageSize = _pageSize,
            Elapsed = _lastQueryElapsed,
            Error = _loadError,
        });
    }

    private static int ReadCount(CSharpDB.Client.Models.SqlExecutionResult result)
    {
        if (!result.IsQuery || result.Rows is not { Count: > 0 } || result.Rows[0].Length == 0 || result.Rows[0][0] is null)
            return 0;

        return Convert.ToInt32(result.Rows[0][0], System.Globalization.CultureInfo.InvariantCulture);
    }

    private void ApplyTableSchema(TableSchema schema)
    {
        Columns = schema.Columns.Select(c => c.Name).ToArray();
        ColumnTypes = schema.Columns.Select(c => c.Type.ToString().ToUpperInvariant()).ToArray();
        PrimaryKeyColumn = schema.Columns.FirstOrDefault(c => c.IsPrimaryKey)?.Name;
    }

    private void MergePendingRows(IReadOnlyList<DataGridRow> pendingRows)
    {
        if (pendingRows.Count == 0)
            return;

        foreach (var pendingRow in pendingRows)
        {
            if (pendingRow.State == RowState.New)
            {
                _allRows.Add(CloneRow(pendingRow));
                continue;
            }

            int existingIndex = FindExistingRowIndex(pendingRow);
            if (existingIndex >= 0)
            {
                _allRows[existingIndex] = CloneRow(pendingRow);
            }
        }
    }

    private int FindExistingRowIndex(DataGridRow pendingRow)
    {
        if (Columns is null || PrimaryKeyColumn is null)
            return -1;

        int pkColIdx = Array.IndexOf(Columns, PrimaryKeyColumn);
        if (pkColIdx < 0 || pkColIdx >= pendingRow.OriginalValues.Length)
            return -1;

        object? pkValue = pendingRow.OriginalValues[pkColIdx];
        return _allRows.FindIndex(row =>
            pkColIdx < row.OriginalValues.Length && AreEqual(row.OriginalValues[pkColIdx], pkValue));
    }

    private static DataGridRow CloneRow(DataGridRow row)
        => new(row.OriginalValues, row.CurrentValues, row.State);

    private static string EscapeLikePattern(string value)
        => value
            .Replace("!", "!!", StringComparison.Ordinal)
            .Replace("%", "!%", StringComparison.Ordinal)
            .Replace("_", "!_", StringComparison.Ordinal);

    private static string EscapeSqlString(string value)
        => value.Replace("'", "''", StringComparison.Ordinal);

    private static bool AreEqual(object? left, object? right)
    {
        if (ReferenceEquals(left, right))
            return true;

        if (left is null || right is null)
            return false;

        if (left is byte[] leftBytes && right is byte[] rightBytes)
            return leftBytes.AsSpan().SequenceEqual(rightBytes);

        return left.Equals(right);
    }

    private static string RequireIdentifier(string identifier)
    {
        if (string.IsNullOrWhiteSpace(identifier))
            throw new InvalidOperationException("Object name is required.");

        for (int i = 0; i < identifier.Length; i++)
        {
            char ch = identifier[i];
            bool isValid = i == 0
                ? char.IsLetter(ch) || ch == '_'
                : char.IsLetterOrDigit(ch) || ch == '_';

            if (!isValid)
                throw new InvalidOperationException($"Unsupported identifier '{identifier}'.");
        }

        return identifier;
    }

    // ─── Helpers ────────────────────
    private static string GetRowClass(DataGridRow row) => row.State switch
    {
        RowState.New => "new-row",
        RowState.Modified => "modified",
        RowState.Deleted => "deleted",
        _ => ""
    };

    private static string GetTypeBadgeClass(string type) => type.ToUpperInvariant() switch
    {
        "INTEGER" or "INT" => "type-integer",
        "TEXT" or "VARCHAR" or "CHAR" => "type-text",
        "REAL" => "type-real",
        "BLOB" => "type-blob",
        _ => "type-other"
    };
}
