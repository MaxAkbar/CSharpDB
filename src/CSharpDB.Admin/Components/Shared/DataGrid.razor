@inject ICSharpDbClient DbClient
@inject DatabaseChangeService Changes
@inject ToastService Toast
@inject ModalService Modal

<div class="grid-container">
    @if (_loading)
    {
        <div class="loading-overlay">
            <div class="spinner"></div>
        </div>
    }
    else if (Columns is null || Columns.Length == 0)
    {
        <div class="empty-state">
            <i class="bi bi-table"></i>
            <p>No data to display</p>
        </div>
    }
    else
    {
        <table class="data-grid">
            <thead>
                <tr>
                    <th class="row-num-header">#</th>
                    @for (int c = 0; c < Columns.Length; c++)
                    {
                        var colIdx = c;
                        var sortIndicator = _sortCol == colIdx ? (_sortAsc ? " \u2191" : " \u2193") : "";
                        <th @onclick="() => SortColumn(colIdx)" class="sortable">
                            <span class="col-name">@Columns[colIdx]</span>
                            @if (ColumnTypes is not null && colIdx < ColumnTypes.Length)
                            {
                                <span class="col-type-badge @GetTypeBadgeClass(ColumnTypes[colIdx])">@ColumnTypes[colIdx]</span>
                            }
                            @if (PrimaryKeyColumn is not null && Columns[colIdx] == PrimaryKeyColumn)
                            {
                                <span class="col-pk-badge">PK</span>
                            }
                            <span class="sort-indicator">@sortIndicator</span>
                        </th>
                    }
                </tr>
                @if (ShowFilters)
                {
                    <tr class="filter-row">
                        <td class="row-num-header"></td>
                        @for (int c = 0; c < Columns.Length; c++)
                        {
                            var colIdx = c;
                            <td>
                                <input type="text" class="filter-input" placeholder="Filter..."
                                       value="@GetFilter(colIdx)"
                                       @oninput="e => SetFilter(colIdx, e.Value?.ToString())" />
                            </td>
                        }
                    </tr>
                }
            </thead>
            <tbody>
                @if (_rows.Count == 0)
                {
                    <tr>
                        <td colspan="@(Columns.Length + 1)" class="empty-cell">No rows found</td>
                    </tr>
                }
                else
                {
                    @for (int r = 0; r < _rows.Count; r++)
                    {
                        var rowIdx = r;
                        var row = _rows[rowIdx];
                        var rowClass = GetRowClass(row);
                        var isSelected = _selectedRows.Contains(row);
                        <tr class="@rowClass @(isSelected ? "selected" : "")">
                            <td class="row-num" @onclick="() => ToggleRowSelect(row)">
                                @((_page - 1) * _pageSize + rowIdx + 1)
                            </td>
                            @for (int c = 0; c < Columns.Length; c++)
                            {
                                var colIdx = c;
                                var isPk = PrimaryKeyColumn is not null && Columns[colIdx] == PrimaryKeyColumn;
                                var cellValue = row.CurrentValues[colIdx];
                                var isEditing = _editingCell?.RowIndex == rowIdx && _editingCell?.ColIndex == colIdx;

                                @if (isEditing)
                                {
                                    <td class="editing">
                                        <input type="text" class="cell-edit-input"
                                               value="@_editingCell!.Value"
                                               @oninput="e => _editingCell!.Value = e.Value?.ToString() ?? string.Empty"
                                               @onblur="() => CommitEdit(rowIdx, colIdx)"
                                               @onkeydown="e => HandleCellKeyDown(e, rowIdx, colIdx)"
                                               autofocus />
                                    </td>
                                }
                                else
                                {
                                    <td class="@(isPk ? "pk-val" : "") @(row.IsColumnModified(colIdx) ? "modified-cell" : "")"
                                        @ondblclick="() => StartEdit(rowIdx, colIdx, isPk)">
                                        @if (cellValue is null)
                                        {
                                            <span class="null-val">NULL</span>
                                        }
                                        else if (cellValue is byte[] bytes)
                                        {
                                            <span class="blob-val">[@bytes.Length bytes]</span>
                                        }
                                        else
                                        {
                                            @cellValue.ToString()
                                        }
                                    </td>
                                }
                            }
                        </tr>
                    }
                }
            </tbody>
        </table>
    }
</div>

@if (_totalRows > 0)
{
    <div class="pagination-bar">
        <div class="page-size-select">
            <select @bind="_pageSize" @bind:after="OnPageSizeChanged">
                <option value="10">10 rows</option>
                <option value="25">25 rows</option>
                <option value="50">50 rows</option>
                <option value="100">100 rows</option>
            </select>
        </div>
        <div class="page-controls">
            <button class="page-btn" disabled="@(_page <= 1)" @onclick="() => GoToPage(1)">
                <i class="bi bi-chevron-double-left"></i>
            </button>
            <button class="page-btn" disabled="@(_page <= 1)" @onclick="() => GoToPage(_page - 1)">
                <i class="bi bi-chevron-left"></i>
            </button>
            <span class="page-info">Page @_page of @TotalPages</span>
            <button class="page-btn" disabled="@(_page >= TotalPages)" @onclick="() => GoToPage(_page + 1)">
                <i class="bi bi-chevron-right"></i>
            </button>
            <button class="page-btn" disabled="@(_page >= TotalPages)" @onclick="() => GoToPage(TotalPages)">
                <i class="bi bi-chevron-double-right"></i>
            </button>
        </div>
        <div class="row-count">@_totalRows rows</div>
    </div>
}

@code {
    [Parameter] public string? TableName { get; set; }
    [Parameter] public string? ViewName { get; set; }
    [Parameter] public string[]? Columns { get; set; }
    [Parameter] public string[]? ColumnTypes { get; set; }
    [Parameter] public string? PrimaryKeyColumn { get; set; }
    [Parameter] public bool IsReadOnly { get; set; }
    [Parameter] public bool ShowFilters { get; set; } = true;
    [Parameter] public EventCallback<string> OnStatusMessage { get; set; }
    [Parameter] public EventCallback<int> OnSelectionChanged { get; set; }

    private List<DataGridRow> _allRows = new();
    private List<DataGridRow> _rows = new();
    private bool _loading;
    private int _page = 1;
    private int _pageSize = 25;
    private int _totalRows;
    private int? _sortCol;
    private bool _sortAsc = true;
    private readonly Dictionary<int, string> _filters = new();
    private readonly HashSet<DataGridRow> _selectedRows = new();
    private EditingCell? _editingCell;
    private string? _lastTableName;
    private string? _lastViewName;
    private bool _sourceInitialized;

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(_totalRows / (double)_pageSize));

    protected override async Task OnParametersSetAsync()
    {
        bool sourceChanged = !_sourceInitialized
            || !string.Equals(_lastTableName, TableName, StringComparison.Ordinal)
            || !string.Equals(_lastViewName, ViewName, StringComparison.Ordinal);

        if (!sourceChanged)
            return;

        _sourceInitialized = true;
        _lastTableName = TableName;
        _lastViewName = ViewName;
        _page = 1;
        _sortCol = null;
        _sortAsc = true;
        _filters.Clear();
        Columns = null;
        ColumnTypes = null;
        PrimaryKeyColumn = null;

        await LoadDataAsync();
    }

    public async Task LoadDataAsync()
    {
        _loading = true;
        _editingCell = null;
        _selectedRows.Clear();
        await NotifySelectionChangedAsync();
        StateHasChanged();

        try
        {
            if (TableName is not null)
            {
                var result = await DbClient.BrowseTableAsync(TableName, _page, _pageSize);
                _totalRows = result.TotalRows;
                _allRows = result.Rows.Select(r => new DataGridRow(r)).ToList();

                if (Columns is null || Columns.Length == 0)
                {
                    var schema = result.Schema;
                    Columns = schema.Columns.Select(c => c.Name).ToArray();
                    ColumnTypes = schema.Columns.Select(c => c.Type.ToString().ToUpperInvariant()).ToArray();
                    PrimaryKeyColumn = schema.Columns.FirstOrDefault(c => c.IsPrimaryKey)?.Name;
                }
            }
            else if (ViewName is not null)
            {
                var result = await DbClient.BrowseViewAsync(ViewName, _page, _pageSize);
                _totalRows = result.TotalRows;
                Columns = result.ColumnNames;
                _allRows = result.Rows.Select(r => new DataGridRow(r)).ToList();
            }

            ApplyFiltersAndSort();
        }
        catch (Exception ex)
        {
            Toast.Error($"Failed to load data: {ex.Message}");
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    // ─── Sorting ────────────────────
    private async Task SortColumn(int colIdx)
    {
        if (_sortCol == colIdx)
            _sortAsc = !_sortAsc;
        else
        {
            _sortCol = colIdx;
            _sortAsc = true;
        }
        ApplyFiltersAndSort();
        await NotifySelectionChangedAsync();
        StateHasChanged();
    }

    // ─── Filtering ──────────────────
    private string GetFilter(int colIdx) => _filters.TryGetValue(colIdx, out var v) ? v : string.Empty;

    private async Task SetFilter(int colIdx, string? value)
    {
        if (string.IsNullOrEmpty(value))
            _filters.Remove(colIdx);
        else
            _filters[colIdx] = value;
        ApplyFiltersAndSort();
        await NotifySelectionChangedAsync();
        StateHasChanged();
    }

    // ─── Row Selection ──────────────
    private async Task ToggleRowSelect(DataGridRow row)
    {
        if (_selectedRows.Contains(row))
            _selectedRows.Remove(row);
        else
            _selectedRows.Add(row);

        await NotifySelectionChangedAsync();
    }

    // ─── Inline Editing ─────────────
    private void StartEdit(int rowIdx, int colIdx, bool isPk)
    {
        var row = _rows[rowIdx];
        bool pkLocked = isPk && row.State != RowState.New;
        if (IsReadOnly || pkLocked || row.State == RowState.Deleted) return;
        var val = row.CurrentValues[colIdx];
        _editingCell = new EditingCell
        {
            RowIndex = rowIdx,
            ColIndex = colIdx,
            Value = val?.ToString() ?? string.Empty
        };
    }

    private void CommitEdit(int rowIdx, int colIdx)
    {
        if (_editingCell is null) return;
        var row = _rows[rowIdx];
        var newValue = ParseCellValue(_editingCell.Value, colIdx);
        row.CurrentValues[colIdx] = newValue;

        if (row.State == RowState.Unmodified)
            row.State = RowState.Modified;

        _editingCell = null;
        ApplyFiltersAndSort();
    }

    private void HandleCellKeyDown(KeyboardEventArgs e, int rowIdx, int colIdx)
    {
        if (e.Key == "Enter")
            CommitEdit(rowIdx, colIdx);
        else if (e.Key == "Escape")
            _editingCell = null;
    }

    private object? ParseCellValue(string text, int colIdx)
    {
        if (string.IsNullOrEmpty(text) || text.Equals("NULL", StringComparison.OrdinalIgnoreCase))
            return null;
        if (ColumnTypes is not null && colIdx < ColumnTypes.Length)
        {
            var type = ColumnTypes[colIdx];
            if (type == "INTEGER" && long.TryParse(text, out var l)) return l;
            if (type == "REAL" && double.TryParse(text, out var d)) return d;
        }
        return text;
    }

    // ─── CRUD Actions (called from DataTab toolbar) ──
    public void AddNewRow()
    {
        if (Columns is null) return;
        var values = new object?[Columns.Length];
        var row = new DataGridRow(values, RowState.New);
        _allRows.Add(row);
        ApplyFiltersAndSort();

        int rowIdx = _rows.IndexOf(row);
        if (rowIdx >= 0 && Columns.Length > 0)
        {
            _editingCell = new EditingCell
            {
                RowIndex = rowIdx,
                ColIndex = 0,
                Value = string.Empty
            };
        }

        StateHasChanged();
    }

    public async Task DeleteSelectedRowsAsync()
    {
        foreach (var row in _selectedRows.ToList())
        {
            if (row.State == RowState.New)
                _allRows.Remove(row);
            else
                row.State = RowState.Deleted;
        }
        _selectedRows.Clear();
        ApplyFiltersAndSort();
        await NotifySelectionChangedAsync();
    }

    public async Task SaveChangesAsync()
    {
        if (TableName is null || PrimaryKeyColumn is null) return;
        int saved = 0, errors = 0;

        var pkColIdx = Array.IndexOf(Columns!, PrimaryKeyColumn);

        foreach (var row in _allRows.ToList())
        {
            try
            {
                switch (row.State)
                {
                    case RowState.New:
                        var insertVals = new Dictionary<string, object?>();
                        for (int c = 0; c < Columns!.Length; c++)
                        {
                            if (row.CurrentValues[c] is not null)
                                insertVals[Columns[c]] = row.CurrentValues[c];
                        }
                            if (insertVals.Count > 0)
                            {
                            await DbClient.InsertRowAsync(TableName, insertVals);
                            saved++;
                        }
                        break;

                    case RowState.Modified:
                        var updateVals = new Dictionary<string, object?>();
                        for (int c = 0; c < Columns!.Length; c++)
                            updateVals[Columns[c]] = row.CurrentValues[c];
                        await DbClient.UpdateRowAsync(TableName, PrimaryKeyColumn, row.OriginalValues[pkColIdx]!, updateVals);
                        saved++;
                        break;

                    case RowState.Deleted:
                        await DbClient.DeleteRowAsync(TableName, PrimaryKeyColumn, row.OriginalValues[pkColIdx]!);
                        saved++;
                        break;
                }
            }
            catch (Exception ex)
            {
                errors++;
                Toast.Error($"Row error: {ex.Message}");
            }
        }

        if (saved > 0) Toast.Success($"{saved} change(s) saved");
        if (errors > 0) Toast.Warning($"{errors} error(s) occurred");
        if (saved > 0) Changes.NotifyChanged();

        await LoadDataAsync();
    }

    public async Task DiscardChangesAsync()
    {
        await LoadDataAsync();
    }

    public bool HasPendingChanges => _allRows.Any(r => r.State != RowState.Unmodified);
    public bool HasSelectedRows => _selectedRows.Count > 0;
    public int SelectedRowCount => _selectedRows.Count;

    private void ApplyFiltersAndSort()
    {
        IEnumerable<DataGridRow> query = _allRows;

        foreach (var filter in _filters)
        {
            string needle = filter.Value;
            if (string.IsNullOrWhiteSpace(needle))
                continue;

            int colIdx = filter.Key;
            query = query.Where(row =>
            {
                if (colIdx < 0 || colIdx >= row.CurrentValues.Length)
                    return false;

                object? value = row.CurrentValues[colIdx];
                string text = value switch
                {
                    null => "NULL",
                    byte[] bytes => $"[{bytes.Length} bytes]",
                    _ => value.ToString() ?? string.Empty
                };
                return text.Contains(needle, StringComparison.OrdinalIgnoreCase);
            });
        }

        if (_sortCol is int sortCol)
        {
            query = _sortAsc
                ? query.OrderBy(row => GetSortValue(row, sortCol), CellValueComparer.Instance)
                : query.OrderByDescending(row => GetSortValue(row, sortCol), CellValueComparer.Instance);
        }

        _rows = query.ToList();
        _selectedRows.RemoveWhere(row => !_rows.Contains(row));
    }

    private static object? GetSortValue(DataGridRow row, int colIdx)
    {
        if (colIdx < 0 || colIdx >= row.CurrentValues.Length)
            return null;

        return row.CurrentValues[colIdx];
    }

    private sealed class CellValueComparer : IComparer<object?>
    {
        public static readonly CellValueComparer Instance = new();

        public int Compare(object? x, object? y)
        {
            if (ReferenceEquals(x, y)) return 0;
            if (x is null) return -1;
            if (y is null) return 1;

            if (x is byte[] xb && y is byte[] yb)
                return xb.Length.CompareTo(yb.Length);

            if (x is IComparable cmp && x.GetType() == y.GetType())
                return cmp.CompareTo(y);

            if (double.TryParse(x.ToString(), out var dx) && double.TryParse(y.ToString(), out var dy))
                return dx.CompareTo(dy);

            return StringComparer.OrdinalIgnoreCase.Compare(x.ToString(), y.ToString());
        }
    }

    private async Task NotifySelectionChangedAsync()
    {
        if (OnSelectionChanged.HasDelegate)
            await OnSelectionChanged.InvokeAsync(_selectedRows.Count);
    }

    // ─── Pagination ─────────────────
    private async Task GoToPage(int page)
    {
        _page = Math.Max(1, Math.Min(TotalPages, page));
        await LoadDataAsync();
    }

    private async Task OnPageSizeChanged()
    {
        _page = 1;
        await LoadDataAsync();
    }

    // ─── Helpers ────────────────────
    private static string GetRowClass(DataGridRow row) => row.State switch
    {
        RowState.New => "new-row",
        RowState.Modified => "modified",
        RowState.Deleted => "deleted",
        _ => ""
    };

    private static string GetTypeBadgeClass(string type) => type.ToUpperInvariant() switch
    {
        "INTEGER" or "INT" => "type-integer",
        "TEXT" or "VARCHAR" or "CHAR" => "type-text",
        "REAL" => "type-real",
        "BLOB" => "type-blob",
        _ => "type-other"
    };
}
