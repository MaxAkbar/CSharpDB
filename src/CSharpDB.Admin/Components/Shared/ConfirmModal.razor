@inject ModalService ModalService
@implements IDisposable

@if (ModalService.IsVisible && ModalService.Current is not null)
{
    <div class="modal-overlay" @onclick="Cancel">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>@ModalService.Current.Title</h3>
                <button class="modal-close" @onclick="Cancel">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div class="modal-body">
                <p>@ModalService.Current.Message</p>
                @if (ModalService.Current.ShowInput)
                {
                    <input type="text"
                           class="modal-input"
                           placeholder="@ModalService.Current.InputPlaceholder"
                           @bind="_inputValue"
                           @onkeydown="OnInputKeyDown" />
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="Cancel">
                    @ModalService.Current.CancelText
                </button>
                <button class="btn @(ModalService.Current.IsDanger ? "btn-danger" : "btn-primary")" @onclick="Confirm">
                    @ModalService.Current.ConfirmText
                </button>
            </div>
        </div>
    </div>
}

@code {
    private string _inputValue = string.Empty;

    protected override void OnInitialized()
    {
        ModalService.OnChange += OnChange;
    }

    private void Confirm()
    {
        if (ModalService.Current?.ShowInput == true)
            ModalService.RespondWithValue(_inputValue);
        else
            ModalService.Respond(true);
    }

    private void Cancel()
    {
        _inputValue = string.Empty;
        ModalService.Respond(false);
    }

    private void OnInputKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            Confirm();
    }

    private void OnChange()
    {
        if (ModalService.Current?.ShowInput == true)
            _inputValue = ModalService.Current.InputValue;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose() => ModalService.OnChange -= OnChange;
}
