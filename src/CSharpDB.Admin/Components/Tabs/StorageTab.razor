@using CSharpDB.Client
@using CSharpDB.Client.Models
@using CSharpDB.Storage.Diagnostics
@using System.Text.Json
@using System.Text.Json.Serialization
@inject ICSharpDbClient DbClient
@inject ToastService Toast
@inject DatabaseChangeService Changes

<div class="storage-tab">
    <div class="toolbar">
        <button class="toolbar-btn" @onclick="RefreshAllAsync" disabled="@_loading">
            <i class="bi bi-arrow-clockwise"></i> Refresh
        </button>
        <div class="toolbar-separator"></div>
        <label class="storage-check">
            <input type="checkbox" @bind="_includeHex" />
            Include Hex Dump
        </label>
        <input class="storage-input mono" type="number" min="0" @bind="_pageIdText" />
        <button class="toolbar-btn" @onclick="InspectPageAsync" disabled="@_loadingPage">
            <i class="bi bi-search"></i> Inspect Page
        </button>
        <div class="toolbar-spacer"></div>
        <div class="toolbar-info">@(_dbReport?.DatabasePath ?? DbClient.DataSource)</div>
    </div>

    <div class="heavy-layout">
        <aside class="heavy-rail">
            <div class="heavy-rail-head">Storage Inspector</div>
            <div class="heavy-rail-section">
                <div class="heavy-rail-label">Overview</div>
                <a class="heavy-rail-item active" href="#storage-summary"><i class="bi bi-speedometer2"></i><span>Summary</span></a>
            </div>
            <div class="heavy-rail-section">
                <div class="heavy-rail-label">Inspect</div>
                <a class="heavy-rail-item" href="#storage-header"><i class="bi bi-file-binary"></i><span>Database header</span></a>
                <a class="heavy-rail-item" href="#storage-wal"><i class="bi bi-journal-text"></i><span>WAL</span></a>
                <a class="heavy-rail-item" href="#storage-space"><i class="bi bi-pie-chart"></i><span>Space usage</span></a>
                <a class="heavy-rail-item" href="#storage-histogram"><i class="bi bi-bar-chart-steps"></i><span>Page histogram</span></a>
                <a class="heavy-rail-item" href="#storage-page"><i class="bi bi-search"></i><span>Page drill-down</span></a>
            </div>
            <div class="heavy-rail-section">
                <div class="heavy-rail-label">Health</div>
                <a class="heavy-rail-item" href="#storage-indexes"><i class="bi bi-shield-check"></i><span>Index checks</span><span class="badge">@IndexIssueBadge</span></a>
                <a class="heavy-rail-item" href="#storage-issues"><i class="bi bi-exclamation-triangle"></i><span>Integrity issues</span><span class="badge @(_combinedIssues.Count > 0 ? "warn" : "")">@_combinedIssues.Count</span></a>
            </div>
            <div class="heavy-rail-section">
                <div class="heavy-rail-label">Operations</div>
                <a class="heavy-rail-item" href="#storage-maintenance"><i class="bi bi-tools"></i><span>Maintenance</span></a>
            </div>
        </aside>

        <main class="heavy-pane">
    @if (_loading)
    {
        <div class="loading-overlay">
            <span class="spinner"></span>
        </div>
    }
    else
    {
        <div class="storage-content" id="storage-summary">
            <div class="heavy-summary-strip">
                <div><span>File</span><strong>@FormatBytes(_maintenanceReport?.SpaceUsage.DatabaseFileBytes ?? 0)</strong></div>
                <div><span>Pages</span><strong>@(_dbReport?.Header.PhysicalPageCount.ToString() ?? "-")</strong></div>
                <div><span>Page size</span><strong>@(_dbReport?.Header.PageSize.ToString() ?? "-")</strong></div>
                <div><span>Issues</span><strong>@_combinedIssues.Count</strong></div>
            </div>

            <div class="storage-grid">
                <section class="storage-card" id="storage-header">
                    <h3>Database Header</h3>
                    @if (_dbReport is not null)
                    {
                        <table class="schema-table">
                            <tbody>
                                <tr><th>File Length</th><td>@_dbReport.Header.FileLengthBytes</td></tr>
                                <tr><th>Physical Pages</th><td>@_dbReport.Header.PhysicalPageCount</td></tr>
                                <tr><th>Declared Pages</th><td>@_dbReport.Header.DeclaredPageCount</td></tr>
                                <tr><th>Magic</th><td>@_dbReport.Header.Magic (@BoolLabel(_dbReport.Header.MagicValid))</td></tr>
                                <tr><th>Version</th><td>@_dbReport.Header.Version (@BoolLabel(_dbReport.Header.VersionValid))</td></tr>
                                <tr><th>Page Size</th><td>@_dbReport.Header.PageSize (@BoolLabel(_dbReport.Header.PageSizeValid))</td></tr>
                                <tr><th>Schema Root</th><td>@_dbReport.Header.SchemaRootPage</td></tr>
                                <tr><th>Freelist Head</th><td>@_dbReport.Header.FreelistHead</td></tr>
                                <tr><th>Change Counter</th><td>@_dbReport.Header.ChangeCounter</td></tr>
                            </tbody>
                        </table>
                    }
                </section>

                <section class="storage-card" id="storage-wal">
                    <h3>WAL</h3>
                    @if (_walReport is not null)
                    {
                        <table class="schema-table">
                            <tbody>
                                <tr><th>Path</th><td class="mono-cell">@_walReport.WalPath</td></tr>
                                <tr><th>Exists</th><td>@(_walReport.Exists ? "Yes" : "No")</td></tr>
                                <tr><th>File Length</th><td>@_walReport.FileLengthBytes</td></tr>
                                <tr><th>Frames</th><td>@_walReport.FullFrameCount</td></tr>
                                <tr><th>Commit Frames</th><td>@_walReport.CommitFrameCount</td></tr>
                                <tr><th>Trailing Bytes</th><td>@_walReport.TrailingBytes</td></tr>
                                <tr><th>Magic</th><td>@_walReport.Magic (@BoolLabel(_walReport.MagicValid))</td></tr>
                                <tr><th>Version</th><td>@_walReport.Version (@BoolLabel(_walReport.VersionValid))</td></tr>
                                <tr><th>Page Size</th><td>@_walReport.PageSize (@BoolLabel(_walReport.PageSizeValid))</td></tr>
                            </tbody>
                        </table>
                    }
                </section>
            </div>

            <div class="storage-grid">
                <section class="storage-card" id="storage-space">
                    <h3>Space Usage</h3>
                    @if (_maintenanceReport is not null)
                    {
                        <table class="schema-table">
                            <tbody>
                                <tr><th>Database File</th><td>@FormatBytes(_maintenanceReport.SpaceUsage.DatabaseFileBytes) (@_maintenanceReport.SpaceUsage.DatabaseFileBytes bytes)</td></tr>
                                <tr><th>WAL File</th><td>@FormatBytes(_maintenanceReport.SpaceUsage.WalFileBytes) (@_maintenanceReport.SpaceUsage.WalFileBytes bytes)</td></tr>
                                <tr><th>Page Size</th><td>@_maintenanceReport.SpaceUsage.PageSizeBytes bytes</td></tr>
                                <tr><th>Physical Pages</th><td>@_maintenanceReport.SpaceUsage.PhysicalPageCount</td></tr>
                                <tr><th>Declared Pages</th><td>@_maintenanceReport.SpaceUsage.DeclaredPageCount</td></tr>
                                <tr><th>Freelist Pages</th><td>@_maintenanceReport.SpaceUsage.FreelistPageCount</td></tr>
                                <tr><th>Freelist Bytes</th><td>@FormatBytes(_maintenanceReport.SpaceUsage.FreelistBytes) (@_maintenanceReport.SpaceUsage.FreelistBytes bytes)</td></tr>
                            </tbody>
                        </table>
                    }
                </section>

                <section class="storage-card" id="storage-fragmentation">
                    <h3>Fragmentation</h3>
                    @if (_maintenanceReport is not null)
                    {
                        <table class="schema-table">
                            <tbody>
                                <tr><th>B+tree Free Bytes</th><td>@FormatBytes(_maintenanceReport.Fragmentation.BTreeFreeBytes) (@_maintenanceReport.Fragmentation.BTreeFreeBytes bytes)</td></tr>
                                <tr><th>Pages With Free Space</th><td>@_maintenanceReport.Fragmentation.PagesWithFreeSpace</td></tr>
                                <tr><th>Tail Freelist Pages</th><td>@_maintenanceReport.Fragmentation.TailFreelistPageCount</td></tr>
                                <tr><th>Tail Freelist Bytes</th><td>@FormatBytes(_maintenanceReport.Fragmentation.TailFreelistBytes) (@_maintenanceReport.Fragmentation.TailFreelistBytes bytes)</td></tr>
                            </tbody>
                        </table>
                    }
                </section>
            </div>

            <section class="storage-card" id="storage-maintenance">
                <h3>Maintenance</h3>
                <div class="storage-subsection">
                    <div class="toolbar">
                        <label class="storage-check">
                            Reindex Scope
                            <select class="storage-input mono" value="@_reindexScope" @onchange="HandleReindexScopeChanged" disabled="@_maintenanceBusy">
                                <option value="@ReindexScope.All">All</option>
                                <option value="@ReindexScope.Table">Table</option>
                                <option value="@ReindexScope.Index">Index</option>
                            </select>
                        </label>

                        @if (_reindexScope == ReindexScope.Table)
                        {
                            <select class="storage-input mono" value="@_reindexName" @onchange="HandleReindexNameChanged" disabled="@_maintenanceBusy">
                                @foreach (var tableName in _availableTables)
                                {
                                    <option value="@tableName">@tableName</option>
                                }
                            </select>
                        }
                        else if (_reindexScope == ReindexScope.Index)
                        {
                            <select class="storage-input mono" value="@_reindexName" @onchange="HandleReindexNameChanged" disabled="@_maintenanceBusy">
                                @foreach (var indexName in _availableIndexes)
                                {
                                    <option value="@indexName">@indexName</option>
                                }
                            </select>
                        }

                        <label class="storage-check">
                            <input type="checkbox" @bind="_allowCorruptIndexRecovery" disabled="@_maintenanceBusy" />
                            Force rebuild corrupt indexes
                        </label>

                        <button class="toolbar-btn" @onclick="RunReindexAsync" disabled="@_maintenanceBusy">
                            <i class="bi bi-arrow-repeat"></i> Reindex
                        </button>

                        <label class="storage-check">
                            <input type="checkbox" @bind="_vacuumConfirmArmed" disabled="@_maintenanceBusy" />
                            Confirm full vacuum rewrite
                        </label>

                        <button class="toolbar-btn" @onclick="RunVacuumAsync" disabled="@(_maintenanceBusy || !_vacuumConfirmArmed)">
                            <i class="bi bi-bounding-box-circles"></i> Vacuum
                        </button>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_maintenanceStatus))
                    {
                        <p class="schema-empty">@_maintenanceStatus</p>
                    }
                </div>

                <div class="storage-subsection">
                    <h4>Backup / Restore</h4>
                    <p class="schema-empty">Paths are resolved on the connected host. For HTTP or gRPC connections, choose server-local paths.</p>

                    <div class="storage-action-row">
                        <input class="storage-input mono storage-path-input"
                               type="text"
                               @bind="_backupPath"
                               placeholder="Backup destination path"
                               disabled="@_maintenanceBusy" />

                        <label class="storage-check">
                            <input type="checkbox" @bind="_backupWithManifest" disabled="@_maintenanceBusy" />
                            Write manifest
                        </label>

                        <button class="toolbar-btn" @onclick="RunBackupAsync" disabled="@(_maintenanceBusy || string.IsNullOrWhiteSpace(_backupPath))">
                            <i class="bi bi-download"></i> Backup
                        </button>
                    </div>

                    <div class="storage-action-row">
                        <input class="storage-input mono storage-path-input"
                               type="text"
                               @bind="_restoreSourcePath"
                               placeholder="Restore source path"
                               disabled="@_maintenanceBusy" />

                        <button class="toolbar-btn" @onclick="ValidateRestoreAsync" disabled="@(_maintenanceBusy || string.IsNullOrWhiteSpace(_restoreSourcePath))">
                            <i class="bi bi-shield-check"></i> Validate
                        </button>

                        <label class="storage-check">
                            <input type="checkbox" @bind="_restoreConfirmArmed" disabled="@_maintenanceBusy" />
                            Confirm replace current database
                        </label>

                        <button class="toolbar-btn danger" @onclick="RunRestoreAsync" disabled="@(_maintenanceBusy || !_restoreConfirmArmed || string.IsNullOrWhiteSpace(_restoreSourcePath))">
                            <i class="bi bi-arrow-counterclockwise"></i> Restore
                        </button>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_backupRestoreStatus))
                    {
                        <p class="schema-empty">@_backupRestoreStatus</p>
                    }
                </div>

                <div class="storage-subsection">
                    <h4>Foreign Key Migration</h4>
                    <p class="schema-empty">Paste a JSON migration spec for older databases. Validation previews violations; apply rewrites only the affected child tables.</p>

                    <textarea class="storage-input mono"
                              rows="12"
                              @bind="_foreignKeyMigrationSpecJson"
                              disabled="@_maintenanceBusy"
                              placeholder='{"validateOnly":true,"violationSampleLimit":100,"constraints":[{"tableName":"orders","columnName":"customer_id","referencedTableName":"customers","referencedColumnName":"id","onDelete":"Restrict"}]}'></textarea>

                    <div class="storage-action-row">
                        <input class="storage-input mono storage-path-input"
                               type="text"
                               @bind="_foreignKeyMigrationBackupPath"
                               placeholder="Optional backup destination path"
                               disabled="@_maintenanceBusy" />

                        <button class="toolbar-btn" @onclick="ValidateForeignKeyMigrationAsync" disabled="@(_maintenanceBusy || string.IsNullOrWhiteSpace(_foreignKeyMigrationSpecJson))">
                            <i class="bi bi-shield-check"></i> Validate
                        </button>

                        <label class="storage-check">
                            <input type="checkbox" @bind="_foreignKeyMigrationConfirmArmed" disabled="@_maintenanceBusy" />
                            Confirm apply migration
                        </label>

                        <button class="toolbar-btn danger" @onclick="RunForeignKeyMigrationAsync" disabled="@(_maintenanceBusy || !_foreignKeyMigrationConfirmArmed || string.IsNullOrWhiteSpace(_foreignKeyMigrationSpecJson))">
                            <i class="bi bi-link-45deg"></i> Apply
                        </button>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_foreignKeyMigrationStatus))
                    {
                        <p class="schema-empty">@_foreignKeyMigrationStatus</p>
                    }

                    @if (_foreignKeyMigrationResult is not null)
                    {
                        <table class="schema-table">
                            <tbody>
                                <tr><th>Validate Only</th><td>@BoolText(_foreignKeyMigrationResult.ValidateOnly)</td></tr>
                                <tr><th>Succeeded</th><td>@BoolText(_foreignKeyMigrationResult.Succeeded)</td></tr>
                                <tr><th>Affected Tables</th><td>@_foreignKeyMigrationResult.AffectedTables</td></tr>
                                <tr><th>Applied Foreign Keys</th><td>@_foreignKeyMigrationResult.AppliedForeignKeys</td></tr>
                                <tr><th>Copied Rows</th><td>@_foreignKeyMigrationResult.CopiedRows</td></tr>
                                <tr><th>Violations</th><td>@_foreignKeyMigrationResult.ViolationCount</td></tr>
                                @if (!string.IsNullOrWhiteSpace(_foreignKeyMigrationResult.BackupDestinationPath))
                                {
                                    <tr><th>Backup</th><td class="mono-cell">@_foreignKeyMigrationResult.BackupDestinationPath</td></tr>
                                }
                            </tbody>
                        </table>

                        @if (_foreignKeyMigrationResult.AppliedConstraints.Count > 0)
                        {
                            <div class="storage-subsection">
                                <h4>Applied Constraints</h4>
                                <table class="schema-table">
                                    <thead>
                                        <tr>
                                            <th>Table</th>
                                            <th>Column</th>
                                            <th>References</th>
                                            <th>On Delete</th>
                                            <th>Constraint</th>
                                            <th>Support Index</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var applied in _foreignKeyMigrationResult.AppliedConstraints.OrderBy(item => item.TableName, StringComparer.OrdinalIgnoreCase).ThenBy(item => item.ColumnName, StringComparer.OrdinalIgnoreCase))
                                        {
                                            <tr>
                                                <td>@applied.TableName</td>
                                                <td>@applied.ColumnName</td>
                                                <td>@($"{applied.ReferencedTableName}({applied.ReferencedColumnName})")</td>
                                                <td>@applied.OnDelete</td>
                                                <td class="mono-cell">@applied.ConstraintName</td>
                                                <td class="mono-cell">@applied.SupportingIndexName</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }

                        @if (_foreignKeyMigrationResult.Violations.Count > 0)
                        {
                            <div class="storage-subsection">
                                <h4>Violation Sample</h4>
                                <table class="schema-table">
                                    <thead>
                                        <tr>
                                            <th>Child Table</th>
                                            <th>Column</th>
                                            <th>Value</th>
                                            <th>Child Key</th>
                                            <th>References</th>
                                            <th>Reason</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var violation in _foreignKeyMigrationResult.Violations)
                                        {
                                            <tr>
                                                <td>@violation.TableName</td>
                                                <td>@violation.ColumnName</td>
                                                <td class="mono-cell">@FormatMigrationValue(violation.ChildValue)</td>
                                                <td class="mono-cell">@($"{violation.ChildKeyColumnName}={FormatMigrationValue(violation.ChildKeyValue)}")</td>
                                                <td>@($"{violation.ReferencedTableName}({violation.ReferencedColumnName})")</td>
                                                <td>@violation.Reason</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    }
                </div>
            </section>

            <section class="storage-card" id="storage-histogram">
                <h3>Page Type Histogram</h3>
                @if (_dbReport?.PageTypeHistogram is not null && _dbReport.PageTypeHistogram.Count > 0)
                {
                    <table class="schema-table">
                        <thead>
                            <tr>
                                <th>Page Type</th>
                                <th>Count</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in _dbReport.PageTypeHistogram.OrderBy(p => p.Key, StringComparer.OrdinalIgnoreCase))
                            {
                                <tr>
                                    <td class="mono-cell">@item.Key</td>
                                    <td>@item.Value</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="schema-empty">No pages were scanned.</p>
                }
            </section>

            <section class="storage-card" id="storage-indexes">
                <h3>Index Checks</h3>
                @if (_indexReport?.Indexes is not null && _indexReport.Indexes.Count > 0)
                {
                    <table class="schema-table">
                        <thead>
                            <tr>
                                <th>Index</th>
                                <th>Table</th>
                                <th>Root</th>
                                <th>Root OK</th>
                                <th>Table OK</th>
                                <th>Columns OK</th>
                                <th>Reachable</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var idx in _indexReport.Indexes.OrderBy(i => i.IndexName, StringComparer.OrdinalIgnoreCase))
                            {
                                <tr>
                                    <td class="mono-cell">@idx.IndexName</td>
                                    <td>@idx.TableName</td>
                                    <td>@idx.RootPage</td>
                                    <td>@BoolText(idx.RootPageValid)</td>
                                    <td>@BoolText(idx.TableExists)</td>
                                    <td>@BoolText(idx.ColumnsExistInTable)</td>
                                    <td>@BoolText(idx.RootTreeReachable)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="schema-empty">No indexes found.</p>
                }
            </section>

            <section class="storage-card" id="storage-issues">
                <h3>Integrity Issues</h3>
                @if (_combinedIssues.Count > 0)
                {
                    <table class="schema-table">
                        <thead>
                            <tr>
                                <th>Severity</th>
                                <th>Code</th>
                                <th>Message</th>
                                <th>Page</th>
                                <th>Offset</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var issue in _combinedIssues)
                            {
                                <tr>
                                    <td>
                                        <span class="storage-badge @SeverityClass(issue.Severity)">@issue.Severity</span>
                                    </td>
                                    <td class="mono-cell">@issue.Code</td>
                                    <td>@issue.Message</td>
                                    <td>@(issue.PageId?.ToString() ?? "-")</td>
                                    <td>@(issue.Offset?.ToString() ?? "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="schema-empty">No warnings or errors detected.</p>
                }
            </section>

            <section class="storage-card" id="storage-page">
                <h3>Page Drill-Down</h3>
                @if (_pageReport is null)
                {
                    <p class="schema-empty">Enter a page id and click <strong>Inspect Page</strong>.</p>
                }
                else if (!_pageReport.Exists)
                {
                    <p class="schema-empty">Page @_pageReport.PageId was not found in the file bounds.</p>
                }
                else
                {
                    <table class="schema-table">
                        <tbody>
                            <tr><th>Page Id</th><td>@_pageReport.PageId</td></tr>
                            <tr><th>Type</th><td>@_pageReport.Page?.PageTypeName (@_pageReport.Page?.PageTypeCode)</td></tr>
                            <tr><th>Cell Count</th><td>@_pageReport.Page?.CellCount</td></tr>
                            <tr><th>Cell Content Start</th><td>@_pageReport.Page?.CellContentStart</td></tr>
                            <tr><th>Free Space Bytes</th><td>@_pageReport.Page?.FreeSpaceBytes</td></tr>
                            <tr><th>Right Child / Next Leaf</th><td>@_pageReport.Page?.RightChildOrNextLeaf</td></tr>
                        </tbody>
                    </table>

                    @if (_pageReport.Issues.Count > 0)
                    {
                        <div class="storage-subsection">
                            <h4>Page Issues</h4>
                            <ul class="storage-issues-list">
                                @foreach (var issue in _pageReport.Issues)
                                {
                                    <li>
                                        <span class="storage-badge @SeverityClass(issue.Severity)">@issue.Severity</span>
                                        <span class="mono-cell">@issue.Code</span> — @issue.Message
                                    </li>
                                }
                            </ul>
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(_pageReport.HexDump))
                    {
                        <div class="storage-subsection">
                            <h4>Hex Dump</h4>
                            <pre class="sql-definition">@_pageReport.HexDump</pre>
                        </div>
                    }
                }
            </section>
        </div>
    }
        </main>
    </div>
</div>

@code {
    private DatabaseInspectReport? _dbReport;
    private DatabaseMaintenanceReport? _maintenanceReport;
    private WalInspectReport? _walReport;
    private IndexInspectReport? _indexReport;
    private PageInspectReport? _pageReport;

    private bool _loading;
    private bool _loadingPage;
    private bool _maintenanceBusy;
    private string _pageIdText = "0";
    private bool _includeHex;
    private ReindexScope _reindexScope = ReindexScope.All;
    private string? _reindexName;
    private bool _allowCorruptIndexRecovery;
    private bool _vacuumConfirmArmed;
    private bool _restoreConfirmArmed;
    private bool _foreignKeyMigrationConfirmArmed;
    private bool _backupWithManifest = true;
    private string? _maintenanceStatus;
    private string? _backupRestoreStatus;
    private string? _foreignKeyMigrationStatus;
    private string? _backupPath;
    private string? _restoreSourcePath;
    private string? _foreignKeyMigrationBackupPath;
    private string _foreignKeyMigrationSpecJson = """
{
  "validateOnly": true,
  "violationSampleLimit": 100,
  "constraints": [
    {
      "tableName": "orders",
      "columnName": "customer_id",
      "referencedTableName": "customers",
      "referencedColumnName": "id",
      "onDelete": "Restrict"
    }
  ]
}
""";
    private ForeignKeyMigrationResult? _foreignKeyMigrationResult;
    private IReadOnlyList<string> _availableTables = [];
    private IReadOnlyList<string> _availableIndexes = [];

    private readonly List<IntegrityIssue> _combinedIssues = new();
    private string IndexIssueBadge
        => _indexReport?.Indexes is null
            ? "-"
            : _indexReport.Indexes.All(index => index.RootPageValid && index.TableExists && index.ColumnsExistInTable && index.RootTreeReachable)
                ? "OK"
                : "Check";

    protected override async Task OnInitializedAsync()
    {
        await RefreshAllAsync();
    }

    private async Task RefreshAllAsync()
    {
        _loading = true;
        try
        {
            _dbReport = await DbClient.InspectStorageAsync(includePages: false);
            _maintenanceReport = await DbClient.GetMaintenanceReportAsync();
            _walReport = await DbClient.CheckWalAsync();
            _indexReport = await DbClient.CheckIndexesAsync();
            _availableTables = await DbClient.GetTableNamesAsync();
            _availableIndexes = (await DbClient.GetIndexesAsync())
                .Select(index => index.IndexName)
                .OrderBy(name => name, StringComparer.OrdinalIgnoreCase)
                .ToArray();
            EnsureBackupRestorePaths();
            EnsureReindexSelection();
            RebuildIssueList();
        }
        catch (Exception ex)
        {
            Toast.Error($"Storage inspection failed: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task RunBackupAsync()
    {
        string? backupPath = _backupPath;
        if (string.IsNullOrWhiteSpace(backupPath))
        {
            Toast.Error("Enter a backup destination path.");
            return;
        }

        _maintenanceBusy = true;
        _backupRestoreStatus = null;
        try
        {
            var result = await DbClient.BackupAsync(new BackupRequest
            {
                DestinationPath = backupPath,
                WithManifest = _backupWithManifest,
            });

            _backupPath = result.DestinationPath;
            _backupRestoreStatus = $"Backup saved to {result.DestinationPath}.";
