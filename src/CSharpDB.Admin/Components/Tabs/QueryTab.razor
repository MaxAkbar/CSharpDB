@using System.Text.Json
@using System.Globalization
@using System.Text
@using System.Text.RegularExpressions
@using CSharpDB.Client.Models
@inject ICSharpDbClient DbClient
@inject DatabaseChangeService Changes
@inject ToastService Toast

<div class="query-tab">
    <div class="toolbar">
        <button class="toolbar-btn primary" @onclick="RunQuery" title="Run (Ctrl+Enter)">
            <i class="bi bi-play-fill"></i> Run
        </button>
        <button class="toolbar-btn" @onclick="RunAnalyzeAsync" disabled="@_loading" title="Refresh persisted table and column statistics">
            <i class="bi bi-bar-chart-line"></i> Analyze
        </button>
        <button class="toolbar-btn" @onclick="ClearEditor">
            <i class="bi bi-eraser"></i> Clear
        </button>
        <div class="toolbar-separator"></div>
        <button class="toolbar-btn" @onclick="FormatSql">
            <i class="bi bi-code-slash"></i> Format
        </button>
        <div class="toolbar-spacer"></div>
        @if (_elapsed is not null)
        {
            <div class="toolbar-info">
                @if (_resultRows is not null)
                {
                    <span>@_resultRows.Count rows</span>
                    <span class="toolbar-separator-text">|</span>
                }
                <span>@_elapsed.Value.TotalMilliseconds.ToString("F1") ms</span>
            </div>
        }
    </div>

    <div class="query-shortcuts-bar">
        <span class="query-saved-label">
            <i class="bi bi-bar-chart-line"></i> Stats
        </span>
        <button class="toolbar-btn"
                @onclick="LoadTableStatsQuery"
                disabled="@_loading"
                title="Open sys.table_stats in this tab">
            <i class="bi bi-table"></i> Table Stats
        </button>
        <button class="toolbar-btn"
                @onclick="LoadColumnStatsQuery"
                disabled="@_loading"
                title="Open sys.column_stats in this tab">
            <i class="bi bi-list-columns"></i> Column Stats
        </button>
    </div>

    <div class="query-saved-bar">
        <span class="query-saved-label">
            <i class="bi bi-bookmark-star"></i> Saved
        </span>
        <input class="query-saved-input"
               @bind="_savedQueryName"
               placeholder="Query name..."
               title="Name for save/update" />
        <button class="toolbar-btn"
                @onclick="SaveQueryAsync"
                disabled="@(_loading || _loadingSavedQueries || string.IsNullOrWhiteSpace(_savedQueryName) || string.IsNullOrWhiteSpace(_sqlText))">
            <i class="bi bi-save"></i> Save
        </button>
        <select class="query-saved-select" @bind="_selectedSavedQueryName" disabled="@_loadingSavedQueries">
            <option value="">Load saved query...</option>
            @foreach (var saved in _savedQueries)
            {
                <option value="@saved.Name">@saved.Name</option>
            }
        </select>
        <button class="toolbar-btn"
                @onclick="LoadSelectedQueryAsync"
                disabled="@(_loadingSavedQueries || string.IsNullOrWhiteSpace(_selectedSavedQueryName))">
            <i class="bi bi-download"></i> Load
        </button>
        <button class="toolbar-btn"
                @onclick="RefreshSavedQueriesAsync"
                disabled="@_loadingSavedQueries"
                title="Refresh saved query list">
            <i class="bi bi-arrow-clockwise"></i>
        </button>
    </div>

    <SqlEditor @ref="_editor"
               @bind-Value="_sqlText"
               OnExecute="RunQuery"
               Height="200"
               Placeholder="Enter SQL query..." />

    <div class="grid-container">
        @if (_loading)
        {
            <div class="loading-overlay">
                <div class="spinner"></div>
            </div>
        }
        else if (_error is not null)
        {
            <div class="query-error">
                <i class="bi bi-exclamation-triangle"></i> @_error
            </div>
        }
        else if (_resultColumns is not null && _resultRows is not null)
        {
            <table class="data-grid query-results">
                <thead>
                    <tr>
                        <th class="row-num-header">#</th>
                        @foreach (var col in _resultColumns)
                        {
                            <th>@col</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @for (int r = 0; r < _resultRows.Count; r++)
                    {
                        <tr>
                            <td class="row-num">@(r + 1)</td>
                            @foreach (var val in _resultRows[r])
                            {
                                <td>
                                    @if (val is null)
                                    {
                                        <span class="null-val">NULL</span>
                                    }
                                    else if (val is byte[] bytes)
                                    {
                                        <span class="blob-val">[@bytes.Length bytes]</span>
                                    }
                                    else
                                    {
                                        @val.ToString()
                                    }
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        }
        else if (_nonQueryMessage is not null)
        {
            <div class="query-message">
                <i class="bi bi-check-circle"></i> @_nonQueryMessage
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-terminal"></i>
                <p>Run a query to see results</p>
            </div>
        }
    </div>
</div>

@code {
    private static readonly Regex s_execRegex = new(
        @"^\s*EXEC(?:UTE)?\s+(?<name>[A-Za-z_][A-Za-z0-9_]*)(?<rest>[\s\S]*)$",
        RegexOptions.IgnoreCase | RegexOptions.Singleline | RegexOptions.Compiled);

    private const string AnalyzeSql = "ANALYZE;";
    private const string TableStatsSql = "SELECT * FROM sys.table_stats ORDER BY table_name;";
    private const string ColumnStatsSql = "SELECT * FROM sys.column_stats ORDER BY table_name, ordinal_position;";

    [Parameter] public TabDescriptor? Tab { get; set; }

    private SqlEditor? _editor;
    private string _sqlText = string.Empty;
    private bool _loading;
    private string? _error;
    private string[]? _resultColumns;
    private List<object?[]>? _resultRows;
    private string? _nonQueryMessage;
    private TimeSpan? _elapsed;
    private IReadOnlyList<SavedQueryDefinition> _savedQueries = [];
    private string _savedQueryName = string.Empty;
    private string? _selectedSavedQueryName;
    private bool _loadingSavedQueries;

    protected override async Task OnInitializedAsync()
    {
        await RefreshSavedQueriesAsync();
    }

    protected override void OnParametersSet()
    {
        if (Tab?.SqlText is not null && string.IsNullOrEmpty(_sqlText))
            _sqlText = Tab.SqlText;
    }

    public async Task RunQuery()
    {
        if (string.IsNullOrWhiteSpace(_sqlText)) return;

        _loading = true;
        _error = null;
        _resultColumns = null;
        _resultRows = null;
        _nonQueryMessage = null;
        StateHasChanged();

        try
        {
            string trimmedSql = _sqlText.Trim();
            if (TryParseExecuteCommand(trimmedSql, out var procedureName, out var args, out var parseError))
            {
                if (parseError is not null)
                {
                    _error = parseError;
                }
                else
                {
                    await RunExecuteCommandAsync(procedureName!, args!);
                }
            }
            else
            {
                var result = await DbClient.ExecuteSqlAsync(trimmedSql);
                _elapsed = result.Elapsed;

                if (result.Error is not null)
                {
                    _error = result.Error;
                }
                else if (result.IsQuery)
                {
                    _resultColumns = result.ColumnNames;
                    _resultRows = result.Rows;
                }
                else
                {
                    _nonQueryMessage = $"{result.RowsAffected} row(s) affected";
                    Toast.Success(_nonQueryMessage);
                }

                Changes.NotifyFromSql(trimmedSql);
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
            // Save SQL text back to tab state for preservation
            if (Tab is not null) Tab.SqlText = _sqlText;
            StateHasChanged();
        }
    }

    private void ClearEditor()
    {
        _sqlText = string.Empty;
        _error = null;
        _resultColumns = null;
        _resultRows = null;
        _nonQueryMessage = null;
        _elapsed = null;
    }

    private void FormatSql()
    {
        _sqlText = SqlFormatter.Format(_sqlText);
    }

    private async Task RunAnalyzeAsync()
    {
        LoadSql(AnalyzeSql);
        await RunQuery();
    }

    private void LoadTableStatsQuery() => LoadSql(TableStatsSql);

    private void LoadColumnStatsQuery() => LoadSql(ColumnStatsSql);

    private async Task SaveQueryAsync()
    {
        string name = _savedQueryName.Trim();
        if (name.Length == 0)
        {
            Toast.Warning("Saved query name is required.");
            return;
        }

        if (string.IsNullOrWhiteSpace(_sqlText))
        {
            Toast.Warning("Cannot save an empty query.");
            return;
        }

        try
        {
            var saved = await DbClient.UpsertSavedQueryAsync(name, _sqlText);
            _savedQueryName = saved.Name;
            _selectedSavedQueryName = saved.Name;
            if (Tab is not null)
                Tab.SqlText = _sqlText;

            await RefreshSavedQueriesAsync();
            Toast.Success($"Saved query '{saved.Name}'.");
        }
        catch (Exception ex)
        {
            Toast.Error($"Failed to save query: {ex.Message}");
        }
    }

    private async Task LoadSelectedQueryAsync()
    {
        if (string.IsNullOrWhiteSpace(_selectedSavedQueryName))
        {
            Toast.Warning("Select a saved query to load.");
            return;
        }

        try
        {
            var saved = await DbClient.GetSavedQueryAsync(_selectedSavedQueryName);
            if (saved is null)
            {
                Toast.Warning($"Saved query '{_selectedSavedQueryName}' was not found.");
                await RefreshSavedQueriesAsync();
                return;
            }

            _sqlText = saved.SqlText;
            _savedQueryName = saved.Name;
            _error = null;
            _nonQueryMessage = null;
            _resultColumns = null;
            _resultRows = null;
            _elapsed = null;

            if (Tab is not null)
                Tab.SqlText = _sqlText;

            Toast.Info($"Loaded query '{saved.Name}'.");
        }
        catch (Exception ex)
        {
            Toast.Error($"Failed to load query: {ex.Message}");
        }
    }

    private async Task RefreshSavedQueriesAsync()
    {
        string? keepSelection = _selectedSavedQueryName;
        _loadingSavedQueries = true;

        try
        {
            _savedQueries = await DbClient.GetSavedQueriesAsync();
            if (!string.IsNullOrWhiteSpace(keepSelection)
                && _savedQueries.Any(q => string.Equals(q.Name, keepSelection, StringComparison.OrdinalIgnoreCase)))
            {
                _selectedSavedQueryName = _savedQueries
                    .First(q => string.Equals(q.Name, keepSelection, StringComparison.OrdinalIgnoreCase))
                    .Name;
            }
            else
            {
                _selectedSavedQueryName = null;
            }
        }
        catch (Exception ex)
        {
            Toast.Error($"Failed to refresh saved queries: {ex.Message}");
            _savedQueries = [];
            _selectedSavedQueryName = null;
        }
        finally
        {
            _loadingSavedQueries = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RunExecuteCommandAsync(string procedureName, IReadOnlyDictionary<string, object?> args)
    {
        var result = await DbClient.ExecuteProcedureAsync(procedureName, args);
        _elapsed = result.Elapsed;

        if (!result.Succeeded)
        {
            _error = result.FailedStatementIndex is int failedIndex
                ? $"Procedure '{procedureName}' failed at statement {failedIndex + 1}: {result.Error}"
                : result.Error ?? $"Procedure '{procedureName}' execution failed.";
            return;
        }

        if (result.Statements.Count == 0)
        {
            _nonQueryMessage = $"Procedure '{procedureName}' executed (no statements).";
            Toast.Success(_nonQueryMessage);
            return;
        }

        var last = result.Statements[^1];
        if (last.IsQuery)
        {
            _resultColumns = last.ColumnNames;
            _resultRows = last.Rows;
            return;
        }

        int affected = result.Statements.Where(s => !s.IsQuery).Sum(s => s.RowsAffected);
        _nonQueryMessage = $"Procedure '{procedureName}' executed. {affected} row(s) affected.";
        Toast.Success(_nonQueryMessage);
        Changes.NotifyChanged();
    }

    private void LoadSql(string sql)
    {
        _sqlText = sql;
        _error = null;
        _resultColumns = null;
        _resultRows = null;
        _nonQueryMessage = null;
        _elapsed = null;

        if (Tab is not null)
            Tab.SqlText = _sqlText;
    }

    private static bool TryParseExecuteCommand(
        string sql,
        out string? procedureName,
        out Dictionary<string, object?>? args,
        out string? error)
    {
        procedureName = null;
        args = null;
        error = null;

        var match = s_execRegex.Match(sql);
        if (!match.Success)
            return false;

        procedureName = match.Groups["name"].Value;
        string rest = match.Groups["rest"].Value.Trim();
        if (rest.EndsWith(';'))
            rest = rest[..^1].TrimEnd();

        if (string.IsNullOrWhiteSpace(rest))
        {
            args = new Dictionary<string, object?>(StringComparer.OrdinalIgnoreCase);
            return true;
        }

        if (rest.StartsWith('{'))
        {
            try
            {
                args = JsonSerializer.Deserialize<Dictionary<string, object?>>(rest)
                    ?? new Dictionary<string, object?>(StringComparer.OrdinalIgnoreCase);
            }
            catch (JsonException ex)
            {
                error = $"Invalid EXEC args JSON: {ex.Message}";
                return true;
            }

            return true;
        }

        if (!TryParseSqlStyleArgs(rest, out var parsedArgs, out var parseError))
        {
            error = parseError;
            return true;
        }

        args = parsedArgs;
        return true;
    }

    private static bool TryParseSqlStyleArgs(
        string text,
        out Dictionary<string, object?> args,
        out string? error)
    {
        args = new Dictionary<string, object?>(StringComparer.OrdinalIgnoreCase);
        error = null;

        int index = 0;
        SkipWhitespace(text, ref index);

        while (index < text.Length)
        {
            if (!TryReadIdentifier(text, ref index, out var name))
            {
                error = $"Invalid EXEC args near position {index + 1}: expected parameter name (e.g. @id).";
                return false;
            }

            SkipWhitespace(text, ref index);
            if (index >= text.Length || text[index] != '=')
            {
                error = $"Invalid EXEC args near position {index + 1}: expected '=' after '{name}'.";
                return false;
            }

            index++;
            SkipWhitespace(text, ref index);

            if (!TryReadArgumentValue(text, ref index, out var value, out error))
                return false;

            if (!args.TryAdd(name!, value))
            {
                error = $"Duplicate EXEC argument '{name}'.";
                return false;
            }

            SkipWhitespace(text, ref index);
            if (index >= text.Length)
                break;

            if (text[index] != ',')
            {
                error = $"Invalid EXEC args near position {index + 1}: expected ',' between arguments.";
                return false;
            }

            index++;
            SkipWhitespace(text, ref index);
            if (index >= text.Length)
            {
                error = "Invalid EXEC args: trailing comma.";
                return false;
            }
        }

        return true;
    }

    private static void SkipWhitespace(string text, ref int index)
    {
        while (index < text.Length && char.IsWhiteSpace(text[index]))
            index++;
    }

    private static bool TryReadIdentifier(string text, ref int index, out string? identifier)
    {
        identifier = null;
        if (index < text.Length && text[index] == '@')
            index++;

        if (index >= text.Length || !(char.IsLetter(text[index]) || text[index] == '_'))
            return false;

        int start = index;
        index++;
        while (index < text.Length)
        {
            char c = text[index];
            if (!(char.IsLetterOrDigit(c) || c == '_'))
                break;
            index++;
        }

        identifier = text[start..index];
        return true;
    }

    private static bool TryReadArgumentValue(
        string text,
        ref int index,
        out object? value,
        out string? error)
    {
        value = null;
        error = null;

        if (index >= text.Length)
        {
            error = "Invalid EXEC args: missing value.";
            return false;
        }

        char c = text[index];
        if (c == '\'')
            return TryReadSingleQuotedString(text, ref index, out value, out error);

        if (c == '"')
            return TryReadDoubleQuotedString(text, ref index, out value, out error);

        int start = index;
        while (index < text.Length && !char.IsWhiteSpace(text[index]) && text[index] != ',')
            index++;

        string token = text[start..index];
        if (token.Length == 0)
        {
            error = "Invalid EXEC args: missing value.";
            return false;
        }

        if (token.Equals("null", StringComparison.OrdinalIgnoreCase))
        {
            value = null;
            return true;
        }

        if (token.Equals("true", StringComparison.OrdinalIgnoreCase))
        {
            value = 1L;
            return true;
        }

        if (token.Equals("false", StringComparison.OrdinalIgnoreCase))
        {
            value = 0L;
            return true;
        }

        if (long.TryParse(token, NumberStyles.Integer, CultureInfo.InvariantCulture, out var longValue))
        {
            value = longValue;
            return true;
        }

        if (double.TryParse(token, NumberStyles.Float | NumberStyles.AllowThousands, CultureInfo.InvariantCulture, out var doubleValue))
        {
            value = doubleValue;
            return true;
        }

        error = $"Invalid EXEC args token '{token}'. Use single quotes for text literals.";
        return false;
    }

    private static bool TryReadSingleQuotedString(
        string text,
        ref int index,
        out object? value,
        out string? error)
    {
        var sb = new StringBuilder();
        index++; // skip opening '
        while (index < text.Length)
        {
            char c = text[index];
            if (c == '\'')
            {
                if (index + 1 < text.Length && text[index + 1] == '\'')
                {
                    sb.Append('\'');
                    index += 2;
                    continue;
                }

                index++; // skip closing '
                value = sb.ToString();
                error = null;
                return true;
            }

            sb.Append(c);
            index++;
        }

        value = null;
        error = "Invalid EXEC args: unterminated single-quoted string literal.";
        return false;
    }

    private static bool TryReadDoubleQuotedString(
        string text,
        ref int index,
        out object? value,
        out string? error)
    {
        var sb = new StringBuilder();
        index++; // skip opening "
        while (index < text.Length)
        {
            char c = text[index];
            if (c == '"')
            {
                if (index + 1 < text.Length && text[index + 1] == '"')
                {
                    sb.Append('"');
                    index += 2;
                    continue;
                }

                index++; // skip closing "
                value = sb.ToString();
                error = null;
                return true;
            }

            sb.Append(c);
            index++;
        }

        value = null;
        error = "Invalid EXEC args: unterminated double-quoted string literal.";
        return false;
    }
}
