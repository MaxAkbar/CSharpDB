@using CSharpDB.Admin.Reports.Models
@using CSharpDB.Admin.Reports.Services
@implements IAsyncDisposable
@inject DatabaseClientHolder DbHolder
@inject DatabaseChangeService Changes
@inject TabManagerService TabManager

<div class="report-designer-admin-shell">
    <div class="toolbar">
        <AdminRouteSelector Tab="Tab" RouteChanged="OnRouteChangedAsync" />
    </div>

    @if (RequiresRouteContext)
    {
        <div class="query-error">
            <i class="bi bi-signpost-split"></i> Select a route before using the report designer on a sharded database.
        </div>
    }
    else
    {
        <CSharpDB.Admin.Reports.Pages.Designer @key="_renderKey"
                                               ReportId="@Tab.ReportId"
                                               InitialSourceKind="@ParseSourceKind(Tab.InitialReportSourceKind)"
                                               InitialSourceName="@Tab.InitialReportSourceName"
                                               DraftJson="@Tab.ReportDesignerStateJson"
                                               ReportRepositoryOverride="@_routeReportRepository"
                                               SourceProviderOverride="@_routeSourceProvider"
                                               OnDraftChanged="OnDraftChanged"
                                               OnReportSaved="OnReportSaved"
                                               OnOpenPreview="OpenPreview" />
    }
</div>

@code {
    [Parameter, EditorRequired] public TabDescriptor Tab { get; set; } = default!;
    private string _renderKey = string.Empty;
    private AdminRouteClientLease? _routeLease;
    private IReportRepository? _routeReportRepository;
    private IReportSourceProvider? _routeSourceProvider;

    private AdminRouteClientLease RouteLease => _routeLease ??= new AdminRouteClientLease(DbHolder);
    private bool RequiresRouteContext => DbHolder.SupportsShardAdmin && DbHolder.SupportsRouteBoundClients && Tab.HasRouteContext != true;

    protected override async Task OnInitializedAsync()
    {
        await RouteLease.UpdateAsync(Tab);
        RebuildRouteServices();
        _renderKey = BuildRenderKey();
        DbHolder.DatabaseChanged += OnDatabaseChanged;
    }

    public async ValueTask DisposeAsync()
    {
        DbHolder.DatabaseChanged -= OnDatabaseChanged;
        if (_routeLease is not null)
            await _routeLease.DisposeAsync();
    }

    private Task OnDraftChanged(string? draftJson)
    {
        Tab.ReportDesignerStateJson = draftJson;
        return Task.CompletedTask;
    }

    private Task OnReportSaved(ReportDefinition report)
    {
        Tab.ReportId = report.ReportId;
        Tab.Title = report.Name;
        Tab.Icon = "bi-file-earmark-richtext";
        Tab.InitialReportSourceKind = report.Source.Kind.ToString();
        Tab.InitialReportSourceName = report.Source.Name;
        Tab.ReportDesignerStateJson = null;
        TabManager.ActivateTab(Tab.Id);
        Changes.NotifyChanged();
        return Task.CompletedTask;
    }

    private Task OpenPreview(string reportId)
    {
        TabManager.OpenReportPreviewTab(reportId, Tab.Title);
        return Task.CompletedTask;
    }

    private void OnDatabaseChanged()
    {
        _ = InvokeAsync(ResetAfterDatabaseChangedAsync);
    }

    private async Task ResetAfterDatabaseChangedAsync()
    {
        Tab.ReportDesignerStateJson = null;
        if (_routeLease is not null)
        {
            await _routeLease.DisposeAsync();
            _routeLease = null;
        }

        await RouteLease.UpdateAsync(Tab);
        RebuildRouteServices();
        _renderKey = BuildRenderKey();
        StateHasChanged();
    }

    private async Task OnRouteChangedAsync(CSharpDbRouteContext? routeContext)
    {
        await RouteLease.UpdateAsync(Tab);
        RebuildRouteServices();
        _renderKey = BuildRenderKey();
    }

    private void RebuildRouteServices()
    {
        if (RouteLease.RouteClient is null)
        {
            _routeReportRepository = null;
            _routeSourceProvider = null;
            return;
        }

        _routeReportRepository = new DbReportRepository(RouteLease.RouteClient);
        _routeSourceProvider = new DbReportSourceProvider(RouteLease.RouteClient);
    }

    private static ReportSourceKind? ParseSourceKind(string? value)
        => Enum.TryParse<ReportSourceKind>(value, out var kind) ? kind : null;

    private string BuildRenderKey() => $"{Tab.Id}:{DbHolder.DataSource}:{Tab.RouteKeyspace}:{Tab.RouteKey}";
}
