    private static CSharpDbShardingOptions CreateDraftOptions(
        CSharpDbShardMapSnapshot map,
        int mapVersion)
    {
        return new CSharpDbShardingOptions
        {
            Keyspace = map.Keyspace,
            MapVersion = Math.Max(1, mapVersion),
            VirtualBucketCount = map.VirtualBucketCount,
            Shards = map.Shards.Select(CreateDraftShard).ToArray(),
            BucketRanges = map.BucketRanges.Select(static range => new CSharpDbShardBucketRange
            {
                StartBucketInclusive = range.StartBucketInclusive,
                EndBucketExclusive = range.EndBucketExclusive,
                ShardId = range.ShardId,
            }).ToArray(),
            ExactKeyPins = new Dictionary<string, string>(map.ExactKeyPins, StringComparer.Ordinal),
            Directories = map.Directories.Select(static directory => new CSharpDbShardDirectoryDefinition
            {
                DirectoryName = directory.DirectoryName,
                TargetKeyspace = directory.TargetKeyspace,
                Description = directory.Description,
                ReadOnly = directory.ReadOnly,
                EntryCount = directory.EntryCount,
            }).ToArray(),
            DirectoryEntries = [],
        };
    }

    private static CSharpDbShardingOptions CreateBootstrapDraftOptions(
        string? masterDataSource,
        string keyspace,
        int virtualBucketCount,
        int shardCount)
    {
        int normalizedBucketCount = Math.Max(1, virtualBucketCount);
        int normalizedShardCount = Math.Clamp(shardCount, 1, normalizedBucketCount);
        string normalizedKeyspace = string.IsNullOrWhiteSpace(keyspace)
            ? "default"
            : keyspace.Trim();

        return new CSharpDbShardingOptions
        {
            Keyspace = normalizedKeyspace,
            MapVersion = 1,
            VirtualBucketCount = normalizedBucketCount,
            Shards = Enumerable.Range(0, normalizedShardCount)
                .Select(index => new CSharpDbShardDefinition
                {
                    ShardId = $"shard-{index}",
                    DataSource = CreateBootstrapShardDataSource(masterDataSource, index),
                })
                .ToArray(),
            BucketRanges = CreateEvenBucketRanges(normalizedBucketCount, normalizedShardCount),
            ExactKeyPins = new Dictionary<string, string>(StringComparer.Ordinal),
            Directories = [],
            DirectoryEntries = [],
        };
    }

    private static CSharpDbShardBucketRange[] CreateEvenBucketRanges(
        int virtualBucketCount,
        int shardCount)
    {
        var ranges = new CSharpDbShardBucketRange[shardCount];
        int start = 0;
        for (int index = 0; index < shardCount; index++)
        {
            int end = index == shardCount - 1
                ? virtualBucketCount
                : Math.Max(start + 1, (index + 1) * virtualBucketCount / shardCount);

            ranges[index] = new CSharpDbShardBucketRange
            {
                StartBucketInclusive = start,
                EndBucketExclusive = end,
                ShardId = $"shard-{index}",
            };
            start = end;
        }

        return ranges;
    }

    private static string CreateBootstrapShardDataSource(string? masterDataSource, int index)
    {
        string? directory = TryGetDataSourceDirectory(masterDataSource);
        return string.IsNullOrWhiteSpace(directory)
            ? $"shard-{index}.db"
            : Path.Combine(directory, $"shard-{index}.db");
    }

    private static string? TryGetDataSourceDirectory(string? dataSource)
    {
        if (string.IsNullOrWhiteSpace(dataSource))
            return null;

        string value = dataSource.Trim();
        if (Uri.TryCreate(value, UriKind.Absolute, out Uri? uri))
        {
            if (!string.Equals(uri.Scheme, Uri.UriSchemeFile, StringComparison.OrdinalIgnoreCase))
                return null;

            value = uri.LocalPath;
        }
        else if (value.Contains("://", StringComparison.Ordinal))
        {
            return null;
        }

        try
        {
            string fullPath = Path.GetFullPath(value);
            return Path.GetDirectoryName(fullPath);
        }
        catch (Exception ex) when (ex is ArgumentException or NotSupportedException or PathTooLongException)
        {
            return null;
        }
    }

    private static CSharpDbShardDefinition CreateDraftShard(CSharpDbShardDefinitionSnapshot shard)
        => new()
        {
            ShardId = shard.ShardId,
            Enabled = shard.Enabled,
            Role = shard.Role,
            PrimaryShardId = shard.PrimaryShardId,
            PromotionEligible = shard.PromotionEligible,
            ReplicationLagBytes = shard.ReplicationLagBytes,
            LastReplicatedUtc = shard.LastReplicatedUtc,
            Transport = shard.Transport,
            Endpoint = shard.Endpoint,
            DataSource = shard.DataSource,
            ApiKeyHeaderName = shard.ApiKeyHeaderName,
        };

    private static string? NormalizeOptional(string? value)
        => string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private static JsonSerializerOptions CreateShardingJsonOptions()
    {
        var options = new JsonSerializerOptions
        {
            PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
            PropertyNameCaseInsensitive = true,
            WriteIndented = true,
            DefaultIgnoreCondition = JsonIgnoreCondition.WhenWritingNull,
        };
        options.Converters.Add(new JsonStringEnumConverter(JsonNamingPolicy.CamelCase));
        return options;
    }

