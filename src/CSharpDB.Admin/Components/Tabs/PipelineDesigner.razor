    private static PrimitiveDbType MapPrimitiveDbType(ClientModels.DbType dbType) => dbType switch
    {
        ClientModels.DbType.Integer => PrimitiveDbType.Integer,
        ClientModels.DbType.Real => PrimitiveDbType.Real,
        ClientModels.DbType.Blob => PrimitiveDbType.Blob,
        _ => PrimitiveDbType.Text,
    };

    private sealed class PipelineDesignerState
    {
        public string Name { get; set; } = string.Empty;
        public string Version { get; set; } = "1.0.0";
        public string Description { get; set; } = string.Empty;
        public MutableSourceDefinition Source { get; } = new();
        public MutableDestinationDefinition Destination { get; } = new();
        public MutableExecutionOptions Options { get; } = new();
        public List<MutableTransformDefinition> Transforms { get; } = [];
        public bool IncrementalEnabled { get; set; }
        public string IncrementalWatermarkColumn { get; set; } = string.Empty;
        public string IncrementalLastProcessedValue { get; set; } = string.Empty;
        public string VersionOrDefault => string.IsNullOrWhiteSpace(Version) ? "1.0.0" : Version;
    }

    private sealed class MutableSourceDefinition
    {
        public PipelineSourceKind Kind { get; set; } = PipelineSourceKind.CsvFile;
        public string Path { get; set; } = string.Empty;
        public string TableName { get; set; } = string.Empty;
        public string QueryText { get; set; } = string.Empty;
        public bool HasHeaderRow { get; set; } = true;
    }

    private sealed class MutableDestinationDefinition
    {
        public PipelineDestinationKind Kind { get; set; } = PipelineDestinationKind.JsonFile;
        public string Path { get; set; } = string.Empty;
        public string TableName { get; set; } = string.Empty;
        public bool Overwrite { get; set; }
    }

    private sealed class MutableExecutionOptions
    {
        public int BatchSize { get; set; } = 100;
        public int CheckpointInterval { get; set; } = 10;
        public PipelineErrorMode ErrorMode { get; set; } = PipelineErrorMode.SkipBadRows;
        public int MaxRejects { get; set; } = 10;
    }

    private sealed class MutableTransformDefinition
    {
        public PipelineTransformKind Kind { get; set; }
        public string SelectColumnsText { get; set; } = string.Empty;
        public List<MutableRenameMapping> RenameMappings { get; set; } = [];
        public List<MutableCastMapping> CastMappings { get; set; } = [];
        public string FilterExpression { get; set; } = string.Empty;
        public List<MutableDerivedColumn> DerivedColumns { get; set; } = [];
        public string DeduplicateKeysText { get; set; } = string.Empty;
    }

    private sealed class MutableRenameMapping
    {
        public string Source { get; set; } = string.Empty;
        public string Target { get; set; } = string.Empty;
    }

    private sealed class MutableCastMapping
    {
        public string Column { get; set; } = string.Empty;
        public PrimitiveDbType TargetType { get; set; } = PrimitiveDbType.Text;
    }

    private sealed class MutableDerivedColumn
    {
        public string Name { get; set; } = string.Empty;
        public string Expression { get; set; } = string.Empty;
    }

    private enum PipelineDesignerPanel
    {
        Package,
        Source,
        Transforms,
        Destination,
        Options,
    }
}
