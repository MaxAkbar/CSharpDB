@using CSharpDB.Pipelines.Models
@using CSharpDB.Pipelines.Serialization
@using ClientModels = CSharpDB.Client.Models
@using PrimitiveDbType = CSharpDB.Primitives.DbType
@inject ICSharpDbClient DbClient

<div class="pipeline-designer-shell">
    <aside class="pipeline-designer-toolbox">
        <div class="pipeline-designer-toolbox-section">
            <div class="pipeline-designer-toolbox-title">Pipeline Shape</div>
            <button type="button" class="pipeline-designer-tool"
                    @onclick="() => SelectPanel(PipelineDesignerPanel.Package)"
                    title="Edit pipeline name, version, and description">
                <span class="pipeline-designer-tool-icon meta"><i class="bi bi-diagram-3"></i></span>
                <span>
                    <strong>Metadata</strong>
                    <small>Name, version, description</small>
                </span>
            </button>
            <button type="button" class="pipeline-designer-tool"
                    @onclick="() => SelectPanel(PipelineDesignerPanel.Source)"
                    title="Edit the pipeline source">
                <span class="pipeline-designer-tool-icon source"><i class="bi bi-box-arrow-in-down"></i></span>
                <span>
                    <strong>Source</strong>
                    <small>CSV, JSON, table, or SQL query</small>
                </span>
            </button>
            <button type="button" class="pipeline-designer-tool"
                    @onclick="() => SelectPanel(PipelineDesignerPanel.Destination)"
                    title="Edit the pipeline destination">
                <span class="pipeline-designer-tool-icon destination"><i class="bi bi-box-arrow-up"></i></span>
                <span>
                    <strong>Destination</strong>
                    <small>Table, CSV, or JSON output</small>
                </span>
            </button>
            <button type="button" class="pipeline-designer-tool"
                    @onclick="() => SelectPanel(PipelineDesignerPanel.Options)"
                    title="Edit batch, checkpoint, and incremental settings">
                <span class="pipeline-designer-tool-icon options"><i class="bi bi-sliders"></i></span>
                <span>
                    <strong>Options</strong>
                    <small>Execution and incremental controls</small>
                </span>
            </button>
        </div>

        <div class="pipeline-designer-toolbox-section">
            <div class="pipeline-designer-toolbox-title">Transforms</div>
            @foreach (var transformKind in SupportedTransformKinds)
            {
                <button type="button" class="pipeline-designer-tool"
                        @onclick="() => AddTransform(transformKind)"
                        title="@GetTransformDescription(transformKind)">
                    <span class="pipeline-designer-tool-icon transform"><i class="@GetTransformIcon(transformKind)"></i></span>
                    <span>
                        <strong>@GetTransformLabel(transformKind)</strong>
                        <small>@GetTransformDescription(transformKind)</small>
                    </span>
                </button>
            }
        </div>
    </aside>

    <section class="pipeline-designer-canvas">
        @if (_loadError is not null)
        {
            <div class="query-error">
                <i class="bi bi-exclamation-triangle"></i> @_loadError
            </div>
        }
        else
        {
            <div class="pipeline-designer-header">
                <div>
                    <h3>@DisplayName</h3>
                    <p>@DisplayDescription</p>
                </div>
                <div class="pipeline-designer-header-badges">
                    <span class="pipeline-designer-badge">v@(_state.VersionOrDefault)</span>
                    <span class="pipeline-designer-badge">@_state.Transforms.Count transform@( _state.Transforms.Count == 1 ? "" : "s")</span>
                </div>
            </div>

            <div class="pipeline-flow">
                <button type="button"
                        class="pipeline-stage-card @PanelClass(PipelineDesignerPanel.Source)"
                        @onclick="() => SelectPanel(PipelineDesignerPanel.Source)">
                    <span class="pipeline-stage-icon source"><i class="bi bi-box-arrow-in-down"></i></span>
                    <div class="pipeline-stage-body">
                        <div class="pipeline-stage-title">Source</div>
                        <div class="pipeline-stage-summary">@GetSourceSummary()</div>
                    </div>
                </button>

                <div class="pipeline-flow-arrow"><i class="bi bi-arrow-down"></i></div>

                <div class="pipeline-stage-stack @PanelClass(PipelineDesignerPanel.Transforms)">
                    <div class="pipeline-stage-stack-header">
                        <div>
                            <div class="pipeline-stage-title">Transform Group</div>
                            <div class="pipeline-stage-summary">Ordered runtime transforms executed between source and destination.</div>
                        </div>
                        <button type="button" class="toolbar-btn"
                                @onclick="() => SelectPanel(PipelineDesignerPanel.Transforms)">
                            <i class="bi bi-pencil"></i> Edit
                        </button>
                    </div>

                    @if (_state.Transforms.Count == 0)
                    {
                        <div class="pipeline-transform-empty">
                            <i class="bi bi-layers"></i>
                            <span>No transforms yet. Add one from the toolbox.</span>
                        </div>
                    }
                    else
                    {
                        @for (var i = 0; i < _state.Transforms.Count; i++)
                        {
                            var transform = _state.Transforms[i];
                            <button type="button"
                                    class="pipeline-transform-card @(IsSelectedTransform(i) ? "selected" : null)"
                                    @onclick="() => SelectTransform(i)">
                                <span class="pipeline-transform-order">@((i + 1).ToString())</span>
                                <span class="pipeline-transform-icon"><i class="@GetTransformIcon(transform.Kind)"></i></span>
                                <span class="pipeline-transform-copy">
                                    <strong>@GetTransformLabel(transform.Kind)</strong>
                                    <small>@GetTransformSummary(transform)</small>
                                </span>
                            </button>
                        }
                    }
                </div>

                <div class="pipeline-flow-arrow"><i class="bi bi-arrow-down"></i></div>

                <button type="button"
                        class="pipeline-stage-card @PanelClass(PipelineDesignerPanel.Destination)"
                        @onclick="() => SelectPanel(PipelineDesignerPanel.Destination)">
                    <span class="pipeline-stage-icon destination"><i class="bi bi-box-arrow-up"></i></span>
                    <div class="pipeline-stage-body">
                        <div class="pipeline-stage-title">Destination</div>
                        <div class="pipeline-stage-summary">@GetDestinationSummary()</div>
                    </div>
                </button>

                <div class="pipeline-flow-arrow"><i class="bi bi-arrow-down"></i></div>

                <button type="button"
                        class="pipeline-stage-card compact @PanelClass(PipelineDesignerPanel.Options)"
                        @onclick="() => SelectPanel(PipelineDesignerPanel.Options)">
                    <span class="pipeline-stage-icon options"><i class="bi bi-sliders"></i></span>
                    <div class="pipeline-stage-body">
                        <div class="pipeline-stage-title">Execution</div>
                        <div class="pipeline-stage-summary">@GetOptionsSummary()</div>
                    </div>
                </button>
            </div>
        }
    </section>

    <aside class="pipeline-designer-inspector">
        @if (_loadError is null)
        {
            @if (_tableLoadError is not null)
            {
                <div class="query-error">
                    <i class="bi bi-exclamation-triangle"></i> @_tableLoadError
                </div>
            }
            @switch (CurrentPanel)
            {
                case PipelineDesignerPanel.Package:
                    <div class="pipeline-inspector-section">
                        <h3>Pipeline Metadata</h3>
                        <p>These values are stored in the package and shown across CLI, API, and Admin surfaces.</p>
                        <div class="schema-edit-grid cols-2">
                            <div class="schema-field">
                                <label>Name</label>
                                <input class="schema-input"
                                       @bind="_state.Name"
                                       @bind:event="oninput"
                                       @bind:after="PublishPackageAsync" />
                            </div>
                            <div class="schema-field">
                                <label>Version</label>
                                <input class="schema-input"
                                       @bind="_state.Version"
                                       @bind:event="oninput"
                                       @bind:after="PublishPackageAsync" />
                            </div>
                        </div>
                        <div class="schema-field">
                            <label>Description</label>
                            <textarea class="schema-textarea"
                                      @bind="_state.Description"
                                      @bind:event="oninput"
                                      @bind:after="PublishPackageAsync"></textarea>
                        </div>
                    </div>
                    break;

                case PipelineDesignerPanel.Source:
                    <div class="pipeline-inspector-section">
                        <h3>Source</h3>
                        <p>Choose the supported runtime source and configure only the fields that apply to that kind.</p>
                        <div class="schema-field">
                            <label>Source Kind</label>
                            <select class="schema-input" value="@_state.Source.Kind" @onchange="OnSourceKindChanged">
                                @foreach (var sourceKind in Enum.GetValues<PipelineSourceKind>())
                                {
                                    <option value="@sourceKind">@GetSourceKindLabel(sourceKind)</option>
                                }
                            </select>
                        </div>
                        @if (_state.Source.Kind is PipelineSourceKind.CsvFile or PipelineSourceKind.JsonFile)
                        {
                            <div class="schema-field">
                                <label>Path</label>
                                <input class="schema-input mono"
                                       @bind="_state.Source.Path"
                                       @bind:event="oninput"
                                       @bind:after="PublishPackageAsync" />
                            </div>
                        }
                        @if (_state.Source.Kind is PipelineSourceKind.CSharpDbTable)
                        {
                            <div class="schema-field">
                                <label>Table Name</label>
                                <div class="pipeline-table-picker">
                                    <input class="schema-input"
                                           list="pipeline-table-list"
                                           value="@_state.Source.TableName"
                                           @onchange="OnSourceTableChanged" />
                                    <button type="button" class="schema-icon-btn" title="Refresh table list" @onclick="RefreshTablesAsync">
                                        <i class="bi bi-arrow-clockwise"></i>
                                    </button>
                                </div>
                            </div>
                            @if (GetSchemaPreview(_state.Source.TableName) is { } sourceSchema)
                            {
                                @RenderSchemaPreview(sourceSchema)
                            }
                        }
                        @if (_state.Source.Kind is PipelineSourceKind.SqlQuery)
                        {
                            <div class="schema-field">
                                <label>SQL Query</label>
                                <textarea class="schema-textarea"
                                          @bind="_state.Source.QueryText"
                                          @bind:event="oninput"
                                          @bind:after="PublishPackageAsync"></textarea>
                            </div>
                            @if (_tableNames.Count > 0)
                            {
                                <div class="pipeline-inspector-subsection">
                                    <h4>Available Tables</h4>
                                    <div class="pipeline-table-chip-row">
                                        @foreach (var tableName in _tableNames.Take(10))
                                        {
                                            <button type="button" class="pipeline-table-chip" @onclick="() => AppendTableNameToQueryAsync(tableName)">
                                                @tableName
                                            </button>
                                        }
                                    </div>
                                </div>
                            }
                        }
                        @if (_state.Source.Kind is PipelineSourceKind.CsvFile)
                        {
                            <label class="schema-check">
                                <input type="checkbox"
                                       @bind="_state.Source.HasHeaderRow"
                                       @bind:after="PublishPackageAsync" />
                                Header row present
                            </label>
                        }
                    </div>
                    break;

                case PipelineDesignerPanel.Transforms:
                    <div class="pipeline-inspector-section">
                        <h3>Transforms</h3>
                        <p>The runtime executes transforms in order. Reorder or remove them here.</p>

                        @if (_state.Transforms.Count == 0)
                        {
                            <p class="schema-empty">No transforms configured yet.</p>
                        }
                        else
                        {
                            @for (var i = 0; i < _state.Transforms.Count; i++)
                            {
                                var transform = _state.Transforms[i];
                                <div class="pipeline-inspector-transform-row @(IsSelectedTransform(i) ? "selected" : null)">
                                    <button type="button" class="pipeline-inspector-transform-main" @onclick="() => SelectTransform(i)">
                                        <span class="pipeline-transform-order">@((i + 1).ToString())</span>
                                        <span>
                                            <strong>@GetTransformLabel(transform.Kind)</strong>
                                            <small>@GetTransformSummary(transform)</small>
                                        </span>
                                    </button>
                                    <div class="pipeline-inspector-transform-actions">
                                        <button type="button" class="schema-icon-btn" title="Move up" disabled="@(i == 0)" @onclick="() => MoveTransform(i, -1)">
                                            <i class="bi bi-arrow-up"></i>
                                        </button>
                                        <button type="button" class="schema-icon-btn" title="Move down" disabled="@(i == _state.Transforms.Count - 1)" @onclick="() => MoveTransform(i, 1)">
                                            <i class="bi bi-arrow-down"></i>
                                        </button>
                                        <button type="button" class="schema-icon-btn danger" title="Remove transform" @onclick="() => RemoveTransform(i)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </div>
                            }
                        }

                        @if (SelectedTransform is not null)
                        {
                            <div class="pipeline-inspector-subsection">
                                <h4>@GetTransformLabel(SelectedTransform.Kind) Settings</h4>
                                <p>@GetTransformDescription(SelectedTransform.Kind)</p>

                                <div class="schema-field">
                                    <label>Transform Kind</label>
                                    <select class="schema-input" value="@SelectedTransform.Kind" @onchange="OnSelectedTransformKindChanged">
                                        @foreach (var transformKind in SupportedTransformKinds)
                                        {
                                            <option value="@transformKind">@GetTransformLabel(transformKind)</option>
                                        }
                                    </select>
                                </div>

                                @switch (SelectedTransform.Kind)
                                {
                                    case PipelineTransformKind.Select:
                                        <div class="schema-field">
                                            <label>Columns</label>
                                            <textarea class="schema-textarea"
                                                      @bind="SelectedTransform.SelectColumnsText"
                                                      @bind:event="oninput"
                                                      @bind:after="PublishPackageAsync"></textarea>
                                        </div>
                                        @if (SchemaColumns.Count > 0)
                                        {
                                            <div class="pipeline-inspector-subsection">
                                                <h4>Available Source Columns</h4>
                                                <div class="pipeline-table-chip-row">
                                                    @foreach (var column in SchemaColumns)
                                                    {
                                                        <button type="button"
                                                                class="pipeline-table-chip @(ContainsLineValue(SelectedTransform.SelectColumnsText, column.Name) ? "selected" : null)"
                                                                @onclick="() => ToggleLineValueAsync(column.Name, true)">
                                                            @column.Name
                                                        </button>
                                                    }
                                                </div>
                                            </div>
                                        }
                                        break;

                                    case PipelineTransformKind.Filter:
                                        <div class="schema-field">
                                            <label>Expression</label>
                                            <textarea class="schema-textarea"
                                                      @bind="SelectedTransform.FilterExpression"
                                                      @bind:event="oninput"
                                                      @bind:after="PublishPackageAsync"></textarea>
                                        </div>
                                        break;

                                    case PipelineTransformKind.Deduplicate:
                                        <div class="schema-field">
                                            <label>Key Columns</label>
                                            <textarea class="schema-textarea"
                                                      @bind="SelectedTransform.DeduplicateKeysText"
                                                      @bind:event="oninput"
                                                      @bind:after="PublishPackageAsync"></textarea>
                                        </div>
                                        @if (SchemaColumns.Count > 0)
                                        {
                                            <div class="pipeline-inspector-subsection">
                                                <h4>Pick Key Columns</h4>
                                                <div class="pipeline-table-chip-row">
                                                    @foreach (var column in SchemaColumns)
                                                    {
                                                        <button type="button"
                                                                class="pipeline-table-chip @(ContainsLineValue(SelectedTransform.DeduplicateKeysText, column.Name) ? "selected" : null)"
                                                                @onclick="() => ToggleLineValueAsync(column.Name, false)">
                                                            @column.Name
                                                        </button>
                                                    }
                                                </div>
                                            </div>
                                        }
                                        break;

                                    case PipelineTransformKind.Rename:
                                        <div class="pipeline-mapping-list">
                                            @for (var i = 0; i < SelectedTransform.RenameMappings.Count; i++)
                                            {
                                                var rename = SelectedTransform.RenameMappings[i];
                                                <div class="pipeline-mapping-row">
                                                    <input class="schema-input mono"
                                                           value="@rename.Source"
                                                           @oninput="e => UpdateRenameMapping(i, true, e.Value?.ToString())"
                                                           list="pipeline-column-list" />
                                                    <span><i class="bi bi-arrow-right"></i></span>
                                                    <input class="schema-input mono"
                                                           value="@rename.Target"
                                                           @oninput="e => UpdateRenameMapping(i, false, e.Value?.ToString())" />
                                                    <button type="button" class="schema-icon-btn danger" @onclick="() => RemoveRenameMapping(i)">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </div>
                                            }
                                            <button type="button" class="toolbar-btn" @onclick="AddRenameMapping">
                                                <i class="bi bi-plus"></i> Add Mapping
                                            </button>
                                            @if (SchemaColumns.Count > 0)
                                            {
                                                <div class="pipeline-table-chip-row">
                                                    @foreach (var column in SchemaColumns)
                                                    {
                                                        <button type="button" class="pipeline-table-chip" @onclick="() => AddRenameMappingFromColumnAsync(column.Name)">
                                                            @column.Name
                                                        </button>
                                                    }
                                                </div>
                                            }
                                        </div>
                                        break;

                                    case PipelineTransformKind.Cast:
                                        <div class="pipeline-mapping-list">
                                            @for (var i = 0; i < SelectedTransform.CastMappings.Count; i++)
                                            {
                                                var cast = SelectedTransform.CastMappings[i];
                                                <div class="pipeline-mapping-row cast">
                                                    <input class="schema-input mono"
                                                           value="@cast.Column"
                                                           @oninput="e => UpdateCastMappingColumn(i, e.Value?.ToString())"
                                                           list="pipeline-column-list" />
                                                    <select class="schema-input"
                                                            value="@cast.TargetType"
                                                            @onchange="e => UpdateCastMappingType(i, e.Value?.ToString())">
                                                        @foreach (var dbType in Enum.GetValues<PrimitiveDbType>())
                                                        {
                                                            <option value="@dbType">@dbType</option>
                                                        }
                                                    </select>
                                                    <button type="button" class="schema-icon-btn danger" @onclick="() => RemoveCastMapping(i)">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </div>
                                            }
                                            <button type="button" class="toolbar-btn" @onclick="AddCastMapping">
                                                <i class="bi bi-plus"></i> Add Cast
                                            </button>
                                            @if (SchemaColumns.Count > 0)
                                            {
                                                <div class="pipeline-table-chip-row">
                                                    @foreach (var column in SchemaColumns)
                                                    {
                                                        <button type="button" class="pipeline-table-chip" @onclick="() => AddCastMappingFromColumnAsync(column)">
                                                            @column.Name : @column.Type
                                                        </button>
                                                    }
                                                </div>
                                            }
                                        </div>
                                        break;

                                    case PipelineTransformKind.Derive:
                                        <div class="pipeline-mapping-list">
                                            @for (var i = 0; i < SelectedTransform.DerivedColumns.Count; i++)
                                            {
                                                var derived = SelectedTransform.DerivedColumns[i];
                                                <div class="pipeline-derived-row">
                                                    <input class="schema-input"
                                                           value="@derived.Name"
                                                           @oninput="e => UpdateDerivedColumnName(i, e.Value?.ToString())" />
                                                    <textarea class="schema-textarea"
                                                              value="@derived.Expression"
                                                              @oninput="e => UpdateDerivedColumnExpression(i, e.Value?.ToString())"></textarea>
                                                    <button type="button" class="schema-icon-btn danger" @onclick="() => RemoveDerivedColumn(i)">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </div>
                                            }
                                            <button type="button" class="toolbar-btn" @onclick="AddDerivedColumn">
                                                <i class="bi bi-plus"></i> Add Derived Column
                                            </button>
                                        </div>
                                        break;
                                }
                            </div>
                        }
                    </div>
                    break;

                case PipelineDesignerPanel.Destination:
                    <div class="pipeline-inspector-section">
                        <h3>Destination</h3>
                        <p>Configure where transformed rows will be written.</p>
                        <div class="schema-field">
                            <label>Destination Kind</label>
                            <select class="schema-input" value="@_state.Destination.Kind" @onchange="OnDestinationKindChanged">
                                @foreach (var destinationKind in Enum.GetValues<PipelineDestinationKind>())
                                {
                                    <option value="@destinationKind">@GetDestinationKindLabel(destinationKind)</option>
                                }
                            </select>
                        </div>
                        @if (_state.Destination.Kind is PipelineDestinationKind.CsvFile or PipelineDestinationKind.JsonFile)
                        {
                            <div class="schema-field">
                                <label>Path</label>
                                <input class="schema-input mono"
                                       @bind="_state.Destination.Path"
                                       @bind:event="oninput"
                                       @bind:after="PublishPackageAsync" />
                            </div>
                        }
                        @if (_state.Destination.Kind is PipelineDestinationKind.CSharpDbTable)
                        {
                            <div class="schema-field">
                                <label>Table Name</label>
                                <div class="pipeline-table-picker">
                                    <input class="schema-input"
                                           list="pipeline-table-list"
                                           value="@_state.Destination.TableName"
                                           @onchange="OnDestinationTableChanged" />
                                    <button type="button" class="schema-icon-btn" title="Refresh table list" @onclick="RefreshTablesAsync">
                                        <i class="bi bi-arrow-clockwise"></i>
                                    </button>
                                </div>
                            </div>
                            @if (GetSchemaPreview(_state.Destination.TableName) is { } destinationSchema)
                            {
                                @RenderSchemaPreview(destinationSchema)
                            }
                        }
                        <label class="schema-check">
                            <input type="checkbox"
                                   @bind="_state.Destination.Overwrite"
                                   @bind:after="PublishPackageAsync" />
                            Overwrite destination before write
                        </label>
                    </div>
                    break;

                case PipelineDesignerPanel.Options:
                    <div class="pipeline-inspector-section">
                        <h3>Execution Options</h3>
                        <p>These settings control batch behavior, checkpointing, rejects, and incremental watermarking.</p>
                        <div class="schema-edit-grid cols-2">
                            <div class="schema-field">
                                <label>Batch Size</label>
                                <input class="schema-input"
                                       type="number"
                                       min="1"
                                       @bind="_state.Options.BatchSize"
                                       @bind:after="PublishPackageAsync" />
                            </div>
                            <div class="schema-field">
                                <label>Checkpoint Interval</label>
                                <input class="schema-input"
                                       type="number"
                                       min="1"
                                       @bind="_state.Options.CheckpointInterval"
                                       @bind:after="PublishPackageAsync" />
                            </div>
                            <div class="schema-field">
                                <label>Error Mode</label>
                                <select class="schema-input" @bind="_state.Options.ErrorMode" @bind:after="PublishPackageAsync">
                                    @foreach (var errorMode in Enum.GetValues<PipelineErrorMode>())
                                    {
                                        <option value="@errorMode">@errorMode</option>
                                    }
                                </select>
                            </div>
                            <div class="schema-field">
                                <label>Max Rejects</label>
                                <input class="schema-input"
                                       type="number"
                                       min="0"
                                       @bind="_state.Options.MaxRejects"
                                       @bind:after="PublishPackageAsync" />
                            </div>
                        </div>
                        <div class="pipeline-inspector-subsection">
                            <h4>Incremental</h4>
                            <label class="schema-check">
                                <input type="checkbox"
                                       @bind="_state.IncrementalEnabled"
                                       @bind:after="PublishPackageAsync" />
                                Enable incremental watermark tracking
                            </label>
                            @if (_state.IncrementalEnabled)
                            {
                                <div class="schema-field">
                                    <label>Watermark Column</label>
                                    <input class="schema-input"
                                           @bind="_state.IncrementalWatermarkColumn"
                                           @bind:event="oninput"
                                           @bind:after="PublishPackageAsync" />
                                </div>
                                <div class="schema-field">
                                    <label>Last Processed Value</label>
                                    <input class="schema-input"
                                           @bind="_state.IncrementalLastProcessedValue"
                                           @bind:event="oninput"
                                           @bind:after="PublishPackageAsync" />
                                </div>
                            }
                        </div>
                    </div>
                    break;
            }
        }
    </aside>
</div>

<datalist id="pipeline-table-list">
    @foreach (var tableName in _tableNames)
    {
        <option value="@tableName"></option>
    }
</datalist>

<datalist id="pipeline-column-list">
    @foreach (var column in SchemaColumns)
    {
        <option value="@column.Name"></option>
    }
</datalist>

@code {
    private static readonly PipelineTransformKind[] SupportedTransformKinds =
    [
        PipelineTransformKind.Select,
        PipelineTransformKind.Rename,
        PipelineTransformKind.Cast,
        PipelineTransformKind.Filter,
        PipelineTransformKind.Derive,
        PipelineTransformKind.Deduplicate,
    ];

    [Parameter] public string PackageJson { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> PackageJsonChanged { get; set; }

    private readonly PipelineDesignerState _state = new();
    private readonly Dictionary<string, ClientModels.TableSchema> _tableSchemas = new(StringComparer.OrdinalIgnoreCase);
    private string? _lastLoadedJson;
    private string? _loadError;
    private string? _tableLoadError;
    private IReadOnlyList<string> _tableNames = [];
    private PipelineDesignerPanel CurrentPanel { get; set; } = PipelineDesignerPanel.Source;
    private int? SelectedTransformIndex { get; set; }

    private string DisplayName => string.IsNullOrWhiteSpace(_state.Name) ? "New Pipeline" : _state.Name;
    private string DisplayDescription => string.IsNullOrWhiteSpace(_state.Description)
        ? "Build a supported linear ETL package and keep raw JSON available when needed."
        : _state.Description;
    private IReadOnlyList<ClientModels.ColumnDefinition> SchemaColumns =>
        GetSchemaPreview(_state.Source.TableName)?.Columns ?? [];

    private MutableTransformDefinition? SelectedTransform =>
        SelectedTransformIndex is int index && index >= 0 && index < _state.Transforms.Count
            ? _state.Transforms[index]
            : null;

    protected override async Task OnInitializedAsync()
    {
        await LoadTableNamesAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (string.Equals(PackageJson, _lastLoadedJson, StringComparison.Ordinal))
        {
            return;
        }

        try
        {
            var package = PipelinePackageSerializer.Deserialize(PackageJson);
            LoadFromPackage(package);
            _loadError = null;
            _lastLoadedJson = PackageJson;
        }
        catch
        {
            var fallbackPackage = CreateDefaultPackage();
            string fallbackJson = PipelinePackageSerializer.Serialize(fallbackPackage);
            LoadFromPackage(fallbackPackage);
            _loadError = null;
            _lastLoadedJson = fallbackJson;

            if (!string.Equals(fallbackJson, PackageJson, StringComparison.Ordinal))
            {
                await PackageJsonChanged.InvokeAsync(fallbackJson);
            }
        }
    }

    private void LoadFromPackage(PipelinePackageDefinition package)
    {
        _state.Name = package.Name;
        _state.Version = package.Version;
        _state.Description = package.Description ?? string.Empty;

        _state.Source.Kind = package.Source.Kind;
        _state.Source.Path = package.Source.Path ?? string.Empty;
        _state.Source.TableName = package.Source.TableName ?? string.Empty;
        _state.Source.QueryText = package.Source.QueryText ?? string.Empty;
        _state.Source.HasHeaderRow = package.Source.HasHeaderRow;

        _state.Destination.Kind = package.Destination.Kind;
        _state.Destination.Path = package.Destination.Path ?? string.Empty;
        _state.Destination.TableName = package.Destination.TableName ?? string.Empty;
        _state.Destination.Overwrite = package.Destination.Overwrite;

        _state.Options.BatchSize = package.Options.BatchSize;
        _state.Options.CheckpointInterval = package.Options.CheckpointInterval;
        _state.Options.ErrorMode = package.Options.ErrorMode;
        _state.Options.MaxRejects = package.Options.MaxRejects;

        _state.IncrementalEnabled = package.Incremental is not null;
        _state.IncrementalWatermarkColumn = package.Incremental?.WatermarkColumn ?? string.Empty;
        _state.IncrementalLastProcessedValue = package.Incremental?.LastProcessedValue ?? string.Empty;

        _state.Transforms.Clear();
        foreach (var transform in package.Transforms)
        {
            _state.Transforms.Add(new MutableTransformDefinition
            {
                Kind = transform.Kind,
                SelectColumnsText = JoinLines(transform.SelectColumns),
                FilterExpression = transform.FilterExpression ?? string.Empty,
                DeduplicateKeysText = JoinLines(transform.DeduplicateKeys),
                RenameMappings = transform.RenameMappings?.Select(static mapping => new MutableRenameMapping
                {
                    Source = mapping.Source,
                    Target = mapping.Target,
                }).ToList() ?? [],
                CastMappings = transform.CastMappings?.Select(static mapping => new MutableCastMapping
                {
                    Column = mapping.Column,
                    TargetType = mapping.TargetType,
                }).ToList() ?? [],
                DerivedColumns = transform.DerivedColumns?.Select(static column => new MutableDerivedColumn
                {
                    Name = column.Name,
                    Expression = column.Expression,
                }).ToList() ?? [],
            });
        }

        if (_state.Transforms.Count == 0)
        {
            SelectedTransformIndex = null;
        }
        else if (SelectedTransformIndex is null || SelectedTransformIndex.Value >= _state.Transforms.Count)
        {
            SelectedTransformIndex = 0;
        }

        _ = EnsureSchemaLoadedAsync(_state.Source.TableName);
        _ = EnsureSchemaLoadedAsync(_state.Destination.TableName);
    }

    private void SelectPanel(PipelineDesignerPanel panel)
    {
        CurrentPanel = panel;
        if (panel != PipelineDesignerPanel.Transforms)
        {
            SelectedTransformIndex = null;
        }
    }

    private void SelectTransform(int index)
    {
        CurrentPanel = PipelineDesignerPanel.Transforms;
        SelectedTransformIndex = index;
    }

    private async Task OnSourceKindChanged(ChangeEventArgs args)
    {
        if (args.Value is null || !Enum.TryParse<PipelineSourceKind>(args.Value.ToString(), out var sourceKind))
        {
            return;
        }

        _state.Source.Kind = sourceKind;
        if (sourceKind != PipelineSourceKind.CSharpDbTable)
        {
            _state.Source.TableName = sourceKind == PipelineSourceKind.SqlQuery ? _state.Source.TableName : string.Empty;
        }

        if (sourceKind == PipelineSourceKind.CSharpDbTable)
        {
            await EnsureSchemaLoadedAsync(_state.Source.TableName);
        }

        await PublishPackageAsync();
    }

    private async Task OnDestinationKindChanged(ChangeEventArgs args)
    {
        if (args.Value is null || !Enum.TryParse<PipelineDestinationKind>(args.Value.ToString(), out var destinationKind))
        {
            return;
        }

        _state.Destination.Kind = destinationKind;
        if (destinationKind == PipelineDestinationKind.CSharpDbTable)
        {
            await EnsureSchemaLoadedAsync(_state.Destination.TableName);
        }

        await PublishPackageAsync();
    }

    private async Task OnSourceTableChanged(ChangeEventArgs args)
    {
        _state.Source.TableName = args.Value?.ToString() ?? string.Empty;
        await EnsureSchemaLoadedAsync(_state.Source.TableName);
        await PublishPackageAsync();
    }

    private async Task OnDestinationTableChanged(ChangeEventArgs args)
    {
        _state.Destination.TableName = args.Value?.ToString() ?? string.Empty;
        await EnsureSchemaLoadedAsync(_state.Destination.TableName);
        await PublishPackageAsync();
