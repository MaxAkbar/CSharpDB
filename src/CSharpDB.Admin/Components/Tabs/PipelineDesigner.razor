    private async Task AppendTableNameToQueryAsync(string tableName)
    {
        if (string.IsNullOrWhiteSpace(tableName))
        {
            return;
        }

        _state.Source.QueryText = string.IsNullOrWhiteSpace(_state.Source.QueryText)
            ? $"SELECT * FROM {tableName}"
            : $"{_state.Source.QueryText.TrimEnd()}{Environment.NewLine}-- source table: {tableName}";

        await PublishPackageAsync();
    }

    private bool IsSelectedTransform(int index) =>
        CurrentPanel == PipelineDesignerPanel.Transforms && SelectedTransformIndex == index;

    private string PanelClass(PipelineDesignerPanel panel) =>
        CurrentPanel == panel ? "selected" : string.Empty;

    private void AddTransform(PipelineTransformKind kind)
    {
        _state.Transforms.Add(CreateDefaultTransform(kind));
        SelectedTransformIndex = _state.Transforms.Count - 1;
        CurrentPanel = PipelineDesignerPanel.Transforms;
        _ = PublishPackageAsync();
    }

    private static MutableTransformDefinition CreateDefaultTransform(PipelineTransformKind kind) => kind switch
    {
        PipelineTransformKind.Select => new() { Kind = kind, SelectColumnsText = "id\nname" },
        PipelineTransformKind.Rename => new()
        {
            Kind = kind,
            RenameMappings = [new MutableRenameMapping { Source = "old_name", Target = "new_name" }],
        },
        PipelineTransformKind.Cast => new()
        {
            Kind = kind,
            CastMappings = [new MutableCastMapping { Column = "amount", TargetType = PrimitiveDbType.Real }],
        },
        PipelineTransformKind.Filter => new() { Kind = kind, FilterExpression = "status == 'active'" },
        PipelineTransformKind.Derive => new()
        {
            Kind = kind,
            DerivedColumns = [new MutableDerivedColumn { Name = "full_name", Expression = "first_name + ' ' + last_name" }],
        },
        PipelineTransformKind.Deduplicate => new() { Kind = kind, DeduplicateKeysText = "id" },
        _ => new() { Kind = kind },
    };

    private async Task PublishPackageAsync()
    {
        try
        {
            string json = PipelinePackageSerializer.Serialize(BuildPackage());
            _loadError = null;
            _lastLoadedJson = json;
            if (!string.Equals(json, PackageJson, StringComparison.Ordinal))
            {
                await PackageJsonChanged.InvokeAsync(json);
            }
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
        }
    }

    private PipelinePackageDefinition BuildPackage()
    {
        return new PipelinePackageDefinition
        {
            Name = _state.Name.Trim(),
            Version = _state.Version.Trim(),
            Description = NullIfBlank(_state.Description),
            Source = new PipelineSourceDefinition
            {
                Kind = _state.Source.Kind,
                Path = UsesSourcePath(_state.Source.Kind) ? NullIfBlank(_state.Source.Path) : null,
                TableName = _state.Source.Kind == PipelineSourceKind.CSharpDbTable ? NullIfBlank(_state.Source.TableName) : null,
                QueryText = _state.Source.Kind == PipelineSourceKind.SqlQuery ? NullIfBlank(_state.Source.QueryText) : null,
                HasHeaderRow = _state.Source.HasHeaderRow,
            },
            Transforms = _state.Transforms.Select(BuildTransform).ToArray(),
            Destination = new PipelineDestinationDefinition
            {
                Kind = _state.Destination.Kind,
                Path = UsesDestinationPath(_state.Destination.Kind) ? NullIfBlank(_state.Destination.Path) : null,
                TableName = _state.Destination.Kind == PipelineDestinationKind.CSharpDbTable ? NullIfBlank(_state.Destination.TableName) : null,
                Overwrite = _state.Destination.Overwrite,
            },
            Options = new PipelineExecutionOptions
            {
                BatchSize = Math.Max(1, _state.Options.BatchSize),
                CheckpointInterval = Math.Max(1, _state.Options.CheckpointInterval),
                ErrorMode = _state.Options.ErrorMode,
                MaxRejects = Math.Max(0, _state.Options.MaxRejects),
            },
            Incremental = _state.IncrementalEnabled
                ? new PipelineIncrementalOptions
                {
                    WatermarkColumn = _state.IncrementalWatermarkColumn.Trim(),
                    LastProcessedValue = NullIfBlank(_state.IncrementalLastProcessedValue),
                }
                : null,
        };
    }

    private static PipelineTransformDefinition BuildTransform(MutableTransformDefinition transform) => new()
    {
        Kind = transform.Kind,
        SelectColumns = transform.Kind == PipelineTransformKind.Select ? SplitLines(transform.SelectColumnsText) : null,
        RenameMappings = transform.Kind == PipelineTransformKind.Rename
            ? transform.RenameMappings
                .Where(static mapping => !string.IsNullOrWhiteSpace(mapping.Source) && !string.IsNullOrWhiteSpace(mapping.Target))
                .Select(static mapping => new PipelineRenameMapping { Source = mapping.Source.Trim(), Target = mapping.Target.Trim() })
                .ToArray()
            : null,
        CastMappings = transform.Kind == PipelineTransformKind.Cast
            ? transform.CastMappings
                .Where(static mapping => !string.IsNullOrWhiteSpace(mapping.Column))
                .Select(static mapping => new PipelineCastMapping { Column = mapping.Column.Trim(), TargetType = mapping.TargetType })
                .ToArray()
            : null,
        FilterExpression = transform.Kind == PipelineTransformKind.Filter ? NullIfBlank(transform.FilterExpression) : null,
        DerivedColumns = transform.Kind == PipelineTransformKind.Derive
            ? transform.DerivedColumns
                .Where(static column => !string.IsNullOrWhiteSpace(column.Name) && !string.IsNullOrWhiteSpace(column.Expression))
                .Select(static column => new PipelineDerivedColumn { Name = column.Name.Trim(), Expression = column.Expression.Trim() })
                .ToArray()
            : null,
        DeduplicateKeys = transform.Kind == PipelineTransformKind.Deduplicate ? SplitLines(transform.DeduplicateKeysText) : null,
    };

    private async Task MoveTransform(int index, int direction)
    {
        int targetIndex = index + direction;
        if (targetIndex < 0 || targetIndex >= _state.Transforms.Count)
        {
            return;
        }

        (_state.Transforms[index], _state.Transforms[targetIndex]) = (_state.Transforms[targetIndex], _state.Transforms[index]);
        SelectedTransformIndex = targetIndex;
        await PublishPackageAsync();
    }

    private async Task RemoveTransform(int index)
    {
        _state.Transforms.RemoveAt(index);
        if (_state.Transforms.Count == 0)
        {
            SelectedTransformIndex = null;
        }
        else if (SelectedTransformIndex is not null)
        {
            SelectedTransformIndex = Math.Min(index, _state.Transforms.Count - 1);
        }

        await PublishPackageAsync();
    }

    private async Task OnSelectedTransformKindChanged(ChangeEventArgs args)
    {
        if (SelectedTransform is null || args.Value is null)
        {
            return;
        }

        if (Enum.TryParse<PipelineTransformKind>(args.Value.ToString(), out var transformKind))
        {
            _state.Transforms[SelectedTransformIndex!.Value] = CreateDefaultTransform(transformKind);
            await PublishPackageAsync();
        }
    }

