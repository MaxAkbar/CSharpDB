    private string GetOptionsSummary()
    {
        string incremental = _state.IncrementalEnabled
            ? $"incremental on {_state.IncrementalWatermarkColumn}"
            : "full load";
        return $"batch {_state.Options.BatchSize}, checkpoint {_state.Options.CheckpointInterval}, {incremental}";
    }

    private static string DisplayValue(string? value, string fallback) =>
        string.IsNullOrWhiteSpace(value) ? fallback : value;

    private static string Truncate(string value, int maxLength) =>
        value.Length <= maxLength ? value : value[..Math.Max(0, maxLength - 1)] + "...";

    private static bool UsesSourcePath(PipelineSourceKind kind) =>
        kind is PipelineSourceKind.CsvFile or PipelineSourceKind.JsonFile;

    private static bool UsesDestinationPath(PipelineDestinationKind kind) =>
        kind is PipelineDestinationKind.CsvFile or PipelineDestinationKind.JsonFile;

    private static string? NullIfBlank(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private static string JoinLines(IReadOnlyList<string>? values) =>
        values is null ? string.Empty : string.Join(Environment.NewLine, values);

    private static string[] SplitLines(string? text) =>
        string.IsNullOrWhiteSpace(text)
            ? []
            : text.Split(['\r', '\n', ','], StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries);

