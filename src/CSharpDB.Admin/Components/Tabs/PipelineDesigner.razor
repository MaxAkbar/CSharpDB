    private Task ToggleLineValueAsync(string value, bool selectColumns)
    {
        if (SelectedTransform is null || string.IsNullOrWhiteSpace(value))
        {
            return Task.CompletedTask;
        }

        string current = selectColumns ? SelectedTransform.SelectColumnsText : SelectedTransform.DeduplicateKeysText;
        var values = SplitLines(current).ToList();
        int existingIndex = values.FindIndex(v => string.Equals(v, value, StringComparison.OrdinalIgnoreCase));
        if (existingIndex >= 0)
        {
            values.RemoveAt(existingIndex);
        }
        else
        {
            values.Add(value);
        }

        string updated = string.Join(Environment.NewLine, values);
        if (selectColumns)
        {
            SelectedTransform.SelectColumnsText = updated;
        }
        else
        {
            SelectedTransform.DeduplicateKeysText = updated;
        }

        return PublishPackageAsync();
    }

    private async Task RefreshTablesAsync()
    {
        await LoadTableNamesAsync();
        await EnsureSchemaLoadedAsync(_state.Source.TableName);
        await EnsureSchemaLoadedAsync(_state.Destination.TableName);
    }

    private async Task LoadTableNamesAsync()
    {
        try
        {
            _tableNames = (await DbClient.GetTableNamesAsync()).OrderBy(static name => name).ToArray();
            _tableLoadError = null;
        }
        catch (Exception ex)
        {
            _tableNames = [];
            _tableLoadError = $"Table discovery failed: {ex.Message}";
        }
    }

    private async Task EnsureSchemaLoadedAsync(string? tableName)
    {
        if (string.IsNullOrWhiteSpace(tableName) || _tableSchemas.ContainsKey(tableName))
        {
            return;
        }

        try
        {
            var schema = await DbClient.GetTableSchemaAsync(tableName);
            if (schema is not null)
            {
                _tableSchemas[tableName] = schema;
                _tableLoadError = null;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception ex)
        {
            _tableLoadError = $"Schema preview for '{tableName}' failed: {ex.Message}";
        }
    }

    private ClientModels.TableSchema? GetSchemaPreview(string? tableName)
    {
        if (string.IsNullOrWhiteSpace(tableName))
        {
            return null;
        }

        return _tableSchemas.TryGetValue(tableName, out var schema) ? schema : null;
    }

    private RenderFragment RenderSchemaPreview(ClientModels.TableSchema schema) => @<div class="pipeline-schema-preview">
        <div class="pipeline-schema-preview-header">
            <strong>@schema.TableName</strong>
            <span>@schema.Columns.Count column@(schema.Columns.Count == 1 ? "" : "s")</span>
        </div>
        <div class="pipeline-schema-preview-columns">
            @foreach (var column in schema.Columns.Take(8))
            {
                <span class="pipeline-schema-chip">@(column.IsPrimaryKey ? "PK " : string.Empty)@column.Name : @column.Type</span>
            }
        </div>
    </div>;

