@using CSharpDB.Admin.Forms.Components.Designer
@implements IDisposable

<div class="layers-panel">
    <div class="layers-header">
        <span>Layers</span>
        <span class="layers-count">@State.Controls.Count</span>
    </div>
    <div class="layers-list">
        @for (var i = State.Controls.Count - 1; i >= 0; i--)
        {
            var idx = i;
            var c = State.Controls[i];
            var isSelected = State.SelectedIds.Contains(c.ControlId);
            var isDragOver = _dragOverIndex == idx;
            <div class="@LayerRowClass(isSelected, isDragOver)"
                 draggable="true"
                 @ondragstart="@(() => OnDragStart(idx))"
                 @ondragover="@(e => OnDragOver(e, idx))"
                 @ondragover:preventDefault="true"
                 @ondrop="@(() => OnDrop(idx))"
                 @ondragend="OnDragEnd"
                 @onclick="@(e => OnLayerClick(c.ControlId, e))">
                <span class="layer-drag-handle" title="Drag to reorder">&#x2630;</span>
                <span class="layer-type-icon">@GetTypeIcon(c.ControlType)</span>
                <span class="layer-label" title="@c.ControlId">@GetLabel(c)</span>
                <span class="layer-index">@idx</span>
            </div>
        }
        @if (State.Controls.Count == 0)
        {
            <div class="layers-empty">No controls</div>
        }
    </div>
</div>

@code {
    [CascadingParameter] public DesignerState State { get; set; } = default!;

    private int _dragStartIndex = -1;
    private int _dragOverIndex = -1;

    protected override void OnInitialized() => State.OnChange += OnStateChanged;
    public void Dispose() => State.OnChange -= OnStateChanged;
    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    private void OnDragStart(int index)
    {
        _dragStartIndex = index;
    }

    private void OnDragOver(DragEventArgs e, int index)
    {
        _dragOverIndex = index;
    }

    private void OnDrop(int targetIndex)
    {
        if (_dragStartIndex >= 0 && _dragStartIndex != targetIndex)
        {
            var c = State.Controls[_dragStartIndex];
            State.MoveToIndex(c.ControlId, targetIndex);
        }
        _dragStartIndex = -1;
        _dragOverIndex = -1;
    }

    private void OnDragEnd()
    {
        _dragStartIndex = -1;
        _dragOverIndex = -1;
    }

    private void OnLayerClick(string controlId, MouseEventArgs e)
    {
        State.SelectControl(controlId, e.ShiftKey);
    }

    private static string GetLabel(CSharpDB.Admin.Forms.Models.ControlDefinition c)
    {
        // Prefer binding field name, then text prop, then control type
        if (c.Binding?.FieldName is { Length: > 0 } fieldName)
            return fieldName;
        if (c.Props.Values.TryGetValue("text", out var textVal) && textVal is string s && s.Length > 0)
            return s;
        return c.ControlType;
    }

    private static string GetTypeIcon(string controlType) => controlType switch
    {
        "label" => "A",
        "text" => "\u2328",
        "textarea" => "\u2263",
        "number" => "#",
        "date" => "\U0001F4C5",
        "checkbox" => "\u2611",
        "radio" => "\u25C9",
        "select" => "\u25BE",
        "lookup" => "\U0001F50D",
        "datagrid" => "\u2637",
        "childtabs" => "\u2630",
        "computed" => "\u03A3",
        _ => "?"
    };

    private static string LayerRowClass(bool selected, bool dragOver)
    {
        var cls = "layer-row";
        if (selected) cls += " layer-selected";
        if (dragOver) cls += " layer-dragover";
        return cls;
    }
}
