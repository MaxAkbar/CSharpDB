<Window x:Class="CSharpDB.Admin.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="CSharpDB Studio"
        Width="1440"
        Height="960"
        MinWidth="1024"
        MinHeight="700"
        Background="#0f172a"
        Loaded="OnLoaded">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem x:Name="OpenDatabaseMenuItem"
                          Header="_Open Database..."
                          IsEnabled="False"
                          Click="OnOpenDatabase" />
                <Separator />
                <MenuItem Header="E_xit" Click="OnExit" />
            </MenuItem>
        </Menu>
        <Grid>
            <wv2:WebView2 x:Name="Browser" Visibility="Collapsed" />
            <Border x:Name="StartupPanel"
                    Background="#0f172a"
                    Padding="32">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MaxWidth="620">
                    <Image x:Name="BrandIcon"
                           Width="72"
                           Height="72"
                           Margin="0,0,0,24" />
                    <TextBlock Text="CSharpDB Studio"
                               Foreground="#f8fafc"
                               FontSize="28"
                               FontWeight="SemiBold"
                               TextAlignment="Center"
                               Margin="0,0,0,12" />
                    <TextBlock x:Name="StatusText"
                               Text="Starting local Admin host..."
                               Foreground="#cbd5e1"
                               FontSize="15"
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
